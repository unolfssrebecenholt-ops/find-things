page {
  min-height: 100%;
  color: #2f352c;
  background: #fff7e8;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
button,
input,
textarea,
image,
swiper {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 22rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 34rpx 36rpx 156rpx;
  background:
    linear-gradient(180deg, #fff9ec 0%, #f4faee 56%, #fff7e8 100%);
}

.eyebrow {
  display: block;
  color: #71915f;
  font-size: 24rpx;
  font-weight: 750;
  line-height: 1.25;
}

.page-title {
  display: block;
  margin-top: 8rpx;
  color: #2f352c;
  font-size: 50rpx;
  font-weight: 850;
  line-height: 1.18;
}

.subtle {
  color: #7b7465;
  font-size: 25rpx;
  line-height: 1.5;
}

.primary-button,
.soft-button,
.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 96rpx;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1.2;
  border-radius: 28rpx;
}

.primary-button {
  color: #ffffff;
  background: #ff7a59;
  box-shadow: 0 10rpx 0 #d9553a;
}

.soft-button {
  color: #486f45;
  background: #e6f6d8;
  box-shadow: 0 8rpx 0 #c7e8b6;
}

.ghost-button {
  color: #486f45;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
}

.primary-button:active,
.soft-button:active,
.ghost-button:active,
.empty-action:active {
  transform: translateY(4rpx);
  box-shadow: none;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 36rpx 0 20rpx;
}

.section-heading {
  color: #2f352c;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.text-link {
  color: #ff7a59;
  font-size: 24rpx;
  font-weight: 700;
}

.pill {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 42rpx;
  padding: 6rpx 14rpx;
  color: #5d6d33;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
  background: #fff0b8;
  border-radius: 999rpx;
}

.empty-state {
  padding: 30rpx;
  color: #7b7465;
  font-size: 27rpx;
  line-height: 1.55;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 0 #f1e4c8;
}

.note-card {
  padding: 22rpx 24rpx;
  color: #775f28;
  font-size: 24rpx;
  line-height: 1.45;
  background: #fff2c8;
  border: 2rpx solid #ecd79a;
  border-radius: 26rpx;
}

.xiaolan-avatar {
  display: block;
  width: 84rpx;
  height: 84rpx;
  flex: none;
}

.xiaolan-avatar.small {
  width: 62rpx;
  height: 62rpx;
}

.xiaolan-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.xiaolan-copy {
  display: grid;
  min-width: 0;
  gap: 6rpx;
}

.xiaolan-name {
  color: #2f352c;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.25;
}

.empty-state.with-xiaolan {
  display: grid;
  gap: 18rpx;
}

.empty-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 180rpx;
  height: 68rpx;
  padding: 0 24rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 68rpx;
  background: #ff7a59;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 0 #d9553a;
}

.bottom-nav {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  height: 152rpx;
  padding: 16rpx 28rpx 32rpx;
  background: rgba(255, 253, 248, 0.96);
  border-top: 2rpx solid rgba(234, 223, 200, 0.9);
  backdrop-filter: blur(18rpx);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  min-height: 104rpx;
  color: #8a7f6e;
  font-size: 22rpx;
  font-weight: 700;
}

.nav-item.active {
  color: #ff7a59;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
  border: 4rpx solid currentColor;
  border-radius: 14rpx;
}

.nav-icon.search {
  border-radius: 50%;
  position: relative;
}

.nav-icon.search::after {
  position: absolute;
  right: -12rpx;
  bottom: -8rpx;
  width: 18rpx;
  height: 4rpx;
  content: "";
  background: currentColor;
  border-radius: 999rpx;
  transform: rotate(45deg);
}

.nav-icon.box {
  border-radius: 10rpx;
}

.nav-icon.box::before {
  position: absolute;
  top: 16rpx;
  right: 8rpx;
  left: 8rpx;
  content: "";
  border-top: 4rpx solid currentColor;
}
