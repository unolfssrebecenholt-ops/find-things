page {
  min-height: 100%;
  color: #151713;
  background: #f3f2ed;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
button,
input,
textarea,
image,
swiper {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 24rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 34rpx 36rpx 156rpx;
  background:
    linear-gradient(90deg, rgba(21, 23, 19, 0.035) 1px, transparent 1px) 0 0 / 72rpx 72rpx,
    linear-gradient(180deg, #f7f6f1 0%, #f3f2ed 100%);
}

.eyebrow {
  display: block;
  color: #1f6048;
  font-size: 24rpx;
  font-weight: 750;
  line-height: 1.25;
}

.page-title {
  display: block;
  margin-top: 8rpx;
  color: #151713;
  font-size: 50rpx;
  font-weight: 850;
  line-height: 1.18;
}

.subtle {
  color: #6f756d;
  font-size: 25rpx;
  line-height: 1.5;
}

.primary-button,
.soft-button,
.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 96rpx;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1.2;
  border-radius: 28rpx;
}

.primary-button {
  color: #ffffff;
  background: #1f6048;
  box-shadow: 0 18rpx 42rpx rgba(31, 96, 72, 0.2);
}

.soft-button {
  color: #143e31;
  background: #dbe9df;
  box-shadow: none;
}

.ghost-button {
  color: #143e31;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
}

.primary-button:active,
.soft-button:active,
.ghost-button:active,
.empty-action:active {
  transform: translateY(4rpx);
  box-shadow: none;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 36rpx 0 20rpx;
}

.section-heading {
  color: #151713;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.text-link {
  color: #1f6048;
  font-size: 24rpx;
  font-weight: 700;
}

.pill {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 42rpx;
  padding: 6rpx 14rpx;
  color: #1f6048;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
  background: #dbe9df;
  border: 1rpx solid rgba(21, 23, 19, 0.08);
  border-radius: 999rpx;
}

.empty-state {
  padding: 30rpx;
  color: #6f756d;
  font-size: 27rpx;
  line-height: 1.55;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 30rpx;
  box-shadow: 0 20rpx 54rpx rgba(22, 25, 18, 0.08);
}

.note-card {
  padding: 22rpx 24rpx;
  color: #425147;
  font-size: 24rpx;
  line-height: 1.45;
  background: #eef4ef;
  border: 2rpx solid rgba(21, 23, 19, 0.1);
  border-radius: 26rpx;
}

.xiaolan-avatar {
  display: block;
  width: 84rpx;
  height: 84rpx;
  flex: none;
}

.xiaolan-avatar.small {
  width: 62rpx;
  height: 62rpx;
}

.xiaolan-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.xiaolan-copy {
  display: grid;
  min-width: 0;
  gap: 6rpx;
}

.xiaolan-name {
  color: #151713;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.25;
}

.sloth-chip {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  flex: none;
  min-width: 0;
  height: 80rpx;
  padding: 10rpx 20rpx 10rpx 10rpx;
  color: #143e31;
  font-size: 24rpx;
  font-weight: 760;
  line-height: 1;
  white-space: nowrap;
  background: rgba(219, 233, 223, 0.78);
  border: 2rpx solid rgba(31, 96, 72, 0.16);
  border-radius: 999rpx;
}

.sloth-chip-avatar,
.sloth-chip image {
  display: block;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.empty-state.with-xiaolan {
  display: grid;
  gap: 18rpx;
}

.empty-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 180rpx;
  height: 68rpx;
  padding: 0 24rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 68rpx;
  background: #1f6048;
  border-radius: 999rpx;
  box-shadow: 0 14rpx 32rpx rgba(31, 96, 72, 0.2);
}

.bottom-nav {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  height: 136rpx;
  padding: 14rpx 28rpx 26rpx;
  background: rgba(251, 251, 247, 0.94);
  border-top: 2rpx solid rgba(21, 23, 19, 0.12);
  backdrop-filter: blur(18rpx);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 104rpx;
  color: #8b9288;
  font-size: 22rpx;
  font-weight: 700;
}

.nav-item.active {
  color: #1f6048;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
  border: 4rpx solid currentColor;
  border-radius: 14rpx;
}

.nav-icon.search {
  border-radius: 50%;
  position: relative;
}

.nav-icon.search::after {
  position: absolute;
  right: -12rpx;
  bottom: -8rpx;
  width: 18rpx;
  height: 4rpx;
  content: "";
  background: currentColor;
  border-radius: 999rpx;
  transform: rotate(45deg);
}

.nav-icon.box {
  border-radius: 10rpx;
}

.nav-icon.box::before {
  position: absolute;
  top: 16rpx;
  right: 8rpx;
  left: 8rpx;
  content: "";
  border-top: 4rpx solid currentColor;
}
