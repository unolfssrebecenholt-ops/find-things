<view class="editor {{editorClass}}">
  <view wx:if="{{showHead}}" class="editor-head">
    <view>
      <text class="editor-title">确认物品清单</text>
      <text class="editor-subtitle">取消勾选或删除的物品不会保存。</text>
    </view>
    <text class="editor-count">{{items.length}} 件</text>
  </view>
  <view wx:for="{{items}}" wx:key="tempId" class="item-card {{item.confirmed ? '' : 'disabled'}}">
    <view wx:if="{{showToolbar}}" class="item-toolbar">
      <view class="item-identity">
        <text class="number">{{item.displayIndex}}</text>
        <view class="identity-stack">
          <text class="identity-copy">小懒识别</text>
          <text class="confidence">{{item.confidenceLabel}}</text>
        </view>
      </view>
      <view class="item-actions">
        <button
          wx:if="{{showKeepAction}}"
          class="action-button keep-toggle {{item.confirmed ? 'checked' : ''}}"
          data-index="{{index}}"
          bindtap="toggleConfirmed"
        >{{item.confirmed ? '保留' : '不存'}}</button>
        <button class="action-button delete" data-index="{{index}}" bindtap="removeItem">删除</button>
      </view>
    </view>

    <view class="name-field">
      <text class="field-caption">物品名称</text>
      <input
        class="name-input"
        placeholder="物品名称"
        value="{{item.displayName}}"
        data-index="{{index}}"
        bindblur="rename"
        bindconfirm="rename"
      />
    </view>

    <view class="field-grid">
      <view class="compact-field">
        <text class="field-caption">类别</text>
        <input
          class="compact-input"
          placeholder="类别"
          value="{{item.category}}"
          data-index="{{index}}"
          bindblur="editCategory"
          bindconfirm="editCategory"
        />
      </view>
      <view class="compact-field">
        <text class="field-caption">搜索标签</text>
        <input
          class="compact-input"
          placeholder="颜色、特征、别名"
          value="{{item.tagText}}"
          data-index="{{index}}"
          bindblur="editTags"
          bindconfirm="editTags"
        />
      </view>
    </view>

    <view wx:if="{{item.hasTags}}" class="tag-row">
      <text wx:for="{{item.tagList}}" wx:for-item="tag" wx:key="*this" class="tag">{{tag}}</text>
    </view>

    <view class="description-field">
      <text class="field-caption">小懒描述</text>
      <textarea
        class="description-input"
        placeholder="位置、外观、用途"
        value="{{item.description}}"
        data-index="{{index}}"
        bindblur="editDescription"
      ></textarea>
    </view>

    <view class="note-field">
      <text class="field-caption">备注</text>
      <textarea
        class="note"
        placeholder="补充品牌、尺寸、用途"
        value="{{item.note}}"
        data-index="{{index}}"
        bindblur="editNote"
      ></textarea>
    </view>
  </view>
</view>
