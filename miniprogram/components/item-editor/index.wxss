.editor {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-width: 0;
  max-width: 100%;
}

.editor view,
.editor text,
.editor button,
.editor input,
.editor textarea {
  box-sizing: border-box;
}

.editor button {
  margin: 0;
  padding: 0;
  min-width: 0;
}

.editor button::after {
  border: 0;
}

.editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 2rpx 2rpx 8rpx;
}

.editor-title {
  display: block;
  color: #2f352c;
  font-size: 31rpx;
  font-weight: 850;
  line-height: 1.25;
}

.editor-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #7b7465;
  font-size: 24rpx;
  line-height: 1.45;
}

.editor-count {
  flex: none;
  min-height: 44rpx;
  padding: 7rpx 14rpx;
  color: #7b5e1e;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 30rpx;
  background: #fff0b8;
  border-radius: 999rpx;
}

.item-card {
  display: grid;
  gap: 14rpx;
  min-width: 0;
  max-width: 100%;
  padding: 18rpx;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 30rpx;
  box-shadow: 0 8rpx 0 #f1e4c8;
}

.item-card.disabled {
  opacity: 0.58;
}

.item-toolbar {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 14rpx;
  align-items: center;
  min-height: 60rpx;
  min-width: 0;
  overflow: hidden;
}

.item-actions {
  display: grid;
  grid-template-columns: repeat(2, 96rpx);
  gap: 6rpx;
  justify-self: end;
  max-width: 100%;
  padding: 4rpx;
  background: #fff0b8;
  border: 2rpx solid #ecd79a;
  border-radius: 22rpx;
}

.action-button {
  width: 96rpx;
  max-width: 100%;
  height: 48rpx;
  padding: 0;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 48rpx;
  border-radius: 18rpx;
}

.keep-toggle {
  color: #725f45;
  background: transparent;
}

.keep-toggle.checked {
  color: #ffffff;
  background: #ff7a59;
}

.item-identity {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 10rpx;
}

.identity-stack {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 8rpx;
}

.number {
  flex: none;
  width: 42rpx;
  height: 42rpx;
  color: #ff7a59;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 42rpx;
  text-align: center;
  background: #ffe8dc;
  border-radius: 50%;
}

.identity-copy {
  min-width: 0;
  overflow: hidden;
  color: #7b7465;
  font-size: 23rpx;
  font-weight: 750;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.confidence {
  flex: none;
  max-width: 108rpx;
  min-height: 42rpx;
  padding: 6rpx 10rpx;
  overflow: hidden;
  color: #7b5e1e;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #fff0b8;
  border-radius: 999rpx;
}

.delete {
  color: #a33b2f;
  background: #ffe8dc;
}

.name-field,
.description-field,
.note-field {
  display: grid;
  min-width: 0;
  gap: 8rpx;
}

.field-caption {
  color: #7b7465;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.25;
}

.name-input {
  width: 100%;
  min-width: 0;
  height: 76rpx;
  padding: 0 16rpx;
  color: #2f352c;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 76rpx;
  background: #fff9ee;
  border: 2rpx solid #eadfc8;
  border-radius: 22rpx;
}

.field-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
  gap: 12rpx;
}

.compact-field {
  display: grid;
  min-width: 0;
  gap: 8rpx;
}

.compact-input {
  width: 100%;
  min-width: 0;
  height: 64rpx;
  padding: 0 14rpx;
  color: #2f352c;
  font-size: 25rpx;
  line-height: 64rpx;
  background: #fff9ee;
  border: 2rpx solid #eadfc8;
  border-radius: 20rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  align-items: center;
}

.tag {
  max-width: 100%;
  padding: 6rpx 10rpx;
  overflow: hidden;
  font-size: 21rpx;
  font-weight: 760;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  border-radius: 999rpx;
}

.tag {
  color: #725f45;
  background: #fff0b8;
  border: 1rpx solid #ecd79a;
}

.description-input,
.note {
  width: 100%;
  min-width: 0;
  height: 132rpx;
  min-height: 0;
  padding: 16rpx;
  color: #2f352c;
  font-size: 25rpx;
  line-height: 1.45;
  background: #fff9ee;
  border: 2rpx solid #eadfc8;
  border-radius: 22rpx;
}

.description-input {
  height: 132rpx;
}

.note {
  height: 112rpx;
}
