.result-card {
  display: grid;
  grid-template-columns: 192rpx minmax(0, 1fr);
  gap: 18rpx;
  min-height: 204rpx;
  padding: 16rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 46rpx rgba(22, 25, 18, 0.07);
}

.photo-wrap {
  position: relative;
  width: 192rpx;
  height: 172rpx;
  overflow: hidden;
  background: #dbe9df;
  border-radius: 24rpx;
}

.photo {
  width: 100%;
  height: 100%;
}

.placeholder-photo {
  position: relative;
  width: 100%;
  height: 100%;
}

.placeholder-line {
  position: absolute;
  left: 22rpx;
  bottom: 48rpx;
  width: 70rpx;
  height: 14rpx;
  background: rgba(31, 96, 72, 0.32);
  border-radius: 999rpx;
}

.placeholder-line.wide {
  bottom: 76rpx;
  width: 112rpx;
  background: rgba(251, 251, 247, 0.78);
}

.placeholder-dot {
  position: absolute;
  right: 26rpx;
  bottom: 44rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(169, 200, 181, 0.72);
  border-radius: 50%;
}

.photo-badge {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 10rpx;
  color: #143e31;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
  background: rgba(251, 251, 247, 0.92);
  border-radius: 999rpx;
}

.result-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 2rpx;
}

.match-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.semantic-percent,
.match-summary {
  max-width: 100%;
  padding: 6rpx 12rpx;
  overflow: hidden;
  color: #1f6048;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #dbe9df;
  border: 1rpx solid rgba(21, 23, 19, 0.08);
  border-radius: 999rpx;
}

.semantic-percent {
  flex: none;
  color: #143e31;
  font-size: 20rpx;
  font-weight: 820;
}

.match-summary {
  min-width: 0;
}

.result-name {
  overflow: hidden;
  color: #151713;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-location {
  overflow: hidden;
  color: #6f756d;
  font-size: 24rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-cta {
  align-self: flex-start;
  margin-top: auto;
  color: #1f6048;
  min-height: 42rpx;
  padding: 7rpx 14rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 28rpx;
  background: #eef4ef;
  border: 1rpx solid rgba(21, 23, 19, 0.08);
  border-radius: 999rpx;
}
