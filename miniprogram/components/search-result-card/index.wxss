.result-card {
  display: grid;
  grid-template-columns: 220rpx minmax(0, 1fr);
  gap: 18rpx;
  min-height: 224rpx;
  padding: 18rpx;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 30rpx;
  box-shadow: 0 8rpx 0 #f1e4c8;
}

.photo-wrap {
  position: relative;
  width: 220rpx;
  height: 204rpx;
  overflow: hidden;
  background: #dff3df;
  border-radius: 24rpx;
}

.photo {
  width: 100%;
  height: 100%;
}

.placeholder-photo {
  position: relative;
  width: 100%;
  height: 100%;
}

.placeholder-line {
  position: absolute;
  left: 22rpx;
  bottom: 48rpx;
  width: 70rpx;
  height: 14rpx;
  background: rgba(255, 122, 89, 0.48);
  border-radius: 999rpx;
}

.placeholder-line.wide {
  bottom: 76rpx;
  width: 112rpx;
  background: rgba(255, 240, 184, 0.8);
}

.placeholder-dot {
  position: absolute;
  right: 26rpx;
  bottom: 44rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(124, 201, 130, 0.72);
  border-radius: 50%;
}

.photo-badge {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 10rpx;
  color: #725f45;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
  background: rgba(255, 253, 248, 0.92);
  border-radius: 999rpx;
}

.result-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 2rpx;
}

.match-summary {
  align-self: flex-start;
  max-width: 100%;
  padding: 6rpx 12rpx;
  overflow: hidden;
  color: #7b5e1e;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #fff0b8;
  border-radius: 999rpx;
}

.result-name {
  overflow: hidden;
  color: #2f352c;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-location {
  overflow: hidden;
  color: #7b7465;
  font-size: 24rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-cta {
  align-self: flex-start;
  margin-top: auto;
  color: #ff7a59;
  min-height: 42rpx;
  padding: 7rpx 14rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 28rpx;
  background: #ffe8dc;
  border-radius: 999rpx;
}
