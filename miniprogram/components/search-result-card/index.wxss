.result-card {
  display: grid;
  grid-template-columns: 220rpx minmax(0, 1fr);
  gap: 18rpx;
  min-height: 224rpx;
  padding: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e4ded1;
  border-radius: 8rpx;
  box-shadow: 0 12rpx 30rpx rgba(89, 79, 55, 0.08);
}

.photo-wrap {
  position: relative;
  width: 220rpx;
  height: 204rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(255, 253, 248, 0.48), rgba(255, 253, 248, 0)),
    #dfe8dd;
  border-radius: 8rpx;
}

.photo {
  width: 100%;
  height: 100%;
}

.placeholder-photo {
  position: relative;
  width: 100%;
  height: 100%;
}

.placeholder-line {
  position: absolute;
  left: 22rpx;
  bottom: 48rpx;
  width: 70rpx;
  height: 14rpx;
  background: rgba(47, 111, 75, 0.42);
  border-radius: 999rpx;
}

.placeholder-line.wide {
  bottom: 76rpx;
  width: 112rpx;
  background: rgba(232, 185, 93, 0.55);
}

.placeholder-dot {
  position: absolute;
  right: 26rpx;
  bottom: 44rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(79, 143, 103, 0.55);
  border-radius: 50%;
}

.photo-badge {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 10rpx;
  color: #2f6f4b;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
  background: rgba(255, 253, 248, 0.88);
  border-radius: 999rpx;
}

.result-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 2rpx;
}

.match-summary {
  align-self: flex-start;
  max-width: 100%;
  padding: 6rpx 12rpx;
  overflow: hidden;
  color: #6a5431;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #fff1cf;
  border-radius: 999rpx;
}

.result-name {
  overflow: hidden;
  color: #253027;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-location {
  overflow: hidden;
  color: #697366;
  font-size: 24rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-cta {
  align-self: flex-start;
  margin-top: auto;
  color: #2f6f4b;
  min-height: 42rpx;
  padding: 7rpx 14rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 28rpx;
  background: #e5f0e7;
  border-radius: 999rpx;
}
