<view class="result-card" bindtap="open">
  <view class="photo-wrap">
    <image wx:if="{{viewModel.hasPhoto}}" class="photo" mode="aspectFill" lazy-load="{{true}}" src="{{viewModel.photo}}"></image>
    <view wx:if="{{viewModel.showPlaceholder}}" class="photo placeholder-photo">
      <view class="placeholder-line wide"></view>
      <view class="placeholder-line"></view>
      <view class="placeholder-dot"></view>
    </view>
    <text wx:if="{{viewModel.photoLabel}}" class="photo-badge">{{viewModel.photoLabel}}</text>
  </view>
  <view class="result-copy">
    <view class="match-row">
      <text wx:if="{{viewModel.semanticPercentText}}" class="semantic-percent">{{viewModel.semanticPercentText}}</text>
      <text class="match-summary">{{viewModel.matchSummary}}</text>
    </view>
    <text class="result-name">{{result.item.displayName}}</text>
    <text class="result-location">{{result.containerName}} · {{viewModel.locationText}}</text>
    <text class="result-cta">查看容器</text>
  </view>
</view>
