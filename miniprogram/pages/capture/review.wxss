.review-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  min-height: 100vh;
  padding-bottom: 196rpx;
  background:
    linear-gradient(90deg, rgba(21, 23, 19, 0.035) 1px, transparent 1px) 0 0 / 72rpx 72rpx,
    linear-gradient(180deg, #f7f6f1 0%, #f3f2ed 100%);
}

.review-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding-top: 12rpx;
}

.review-head .pill {
  flex: none;
  margin-top: 6rpx;
}

.sloth-chip {
  display: inline-flex;
  flex: none;
  align-items: center;
  gap: 14rpx;
  height: 80rpx;
  padding: 10rpx 20rpx 10rpx 10rpx;
  color: #143e31;
  background: rgba(219, 233, 223, 0.78);
  border: 2rpx solid rgba(31, 96, 72, 0.16);
  border-radius: 999rpx;
  white-space: nowrap;
}

.sloth-chip image {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.sloth-chip text {
  font-size: 24rpx;
  font-weight: 760;
}

.ratio-guide {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 20rpx;
  color: #6f756d;
  background: rgba(219, 233, 223, 0.44);
  border: 2rpx solid rgba(31, 96, 72, 0.12);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 720;
  line-height: 1;
}

.ratio-guide-strong {
  color: #1f6048;
  font-size: 26rpx;
  font-weight: 860;
}

.summary-panel {
  display: grid;
  gap: 16rpx;
}

.photo-map {
  position: relative;
  height: 382rpx;
  overflow: hidden;
  background: #dbe9df;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 30rpx;
  box-shadow: 0 22rpx 58rpx rgba(22, 25, 18, 0.08);
}

.photo-map.ratio-landscape {
  height: 382rpx;
}

.photo-map.ratio-portrait {
  width: 45%;
  height: 560rpx;
  margin-right: auto;
  margin-left: auto;
}

.photo-map.ratio-square {
  width: 78%;
  height: auto;
  aspect-ratio: 1 / 1;
  margin-right: auto;
  margin-left: auto;
}

.plain-photo {
  width: 100%;
  height: 100%;
}

.annotation-layer {
  position: absolute;
  inset: 0;
}

.annotation-box {
  position: absolute;
  min-width: 44rpx;
  min-height: 44rpx;
  border: 3rpx dashed rgba(251, 251, 247, 0.92);
  border-radius: 18rpx;
  box-shadow: 0 0 0 2rpx rgba(31, 96, 72, 0.42);
}

.annotation-index {
  position: absolute;
  top: -18rpx;
  left: -18rpx;
  width: 40rpx;
  height: 40rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 40rpx;
  text-align: center;
  background: #1f6048;
  border-radius: 50%;
}

.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 28rpx;
}

.summary-title {
  display: block;
  color: #151713;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.3;
}

.quick-list {
  display: grid;
  gap: 8rpx;
}

.quick-item {
  position: relative;
  display: grid;
  gap: 10rpx;
  min-height: 92rpx;
  padding: 14rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 26rpx;
}

.quick-item.expanded {
  padding: 14rpx;
  border-color: rgba(31, 96, 72, 0.2);
  box-shadow: 0 18rpx 46rpx rgba(22, 25, 18, 0.07);
}

.quick-toolbar {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 154rpx;
  gap: 12rpx;
  align-items: center;
  min-height: 52rpx;
}

.quick-identity {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 8rpx;
}

.quick-index {
  flex: none;
  width: 42rpx;
  height: 42rpx;
  color: #1f6048;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 42rpx;
  text-align: center;
  background: #dbe9df;
  border-radius: 50%;
}

.quick-identity-copy {
  min-width: 0;
  overflow: hidden;
  color: #6f756d;
  font-size: 23rpx;
  font-weight: 750;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-confidence {
  flex: none;
  max-width: 108rpx;
  min-height: 42rpx;
  padding: 6rpx 10rpx;
  overflow: hidden;
  color: #143e31;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #eef4ef;
  border: 1rpx solid rgba(31, 96, 72, 0.1);
  border-radius: 999rpx;
}

.quick-copy {
  min-width: 0;
}

.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.mini-tag {
  max-width: 100%;
  padding: 5rpx 10rpx;
  overflow: hidden;
  color: #425147;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #dbe9df;
  border: 1rpx solid rgba(21, 23, 19, 0.08);
  border-radius: 999rpx;
}

.quick-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  justify-self: end;
  width: 154rpx;
  min-width: 154rpx;
}

.quick-action {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  min-width: 0;
  max-width: 72rpx;
  height: 44rpx;
  margin: 0;
  padding: 0;
  overflow: hidden;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 44rpx;
  text-align: center;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.quick-action-spacer {
  width: 72rpx;
  height: 44rpx;
}

.quick-action::after {
  border: 0;
}

.expand-button,
.collapse-action {
  color: #5a645c;
  background: transparent;
  border: 0;
}

.quick-action.delete {
  color: #b13a32;
  background: #f4e5df;
  border: 1rpx solid rgba(177, 58, 50, 0.16);
  box-shadow: none;
}

.quick-name {
  display: block;
  overflow: hidden;
  color: #151713;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.expand-button::after {
  border: 0;
}

.quick-editor {
  min-width: 0;
}

.quick-editor .editor {
  display: block;
}

.review-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 35;
  display: grid;
  grid-template-columns: 0.9fr 1.15fr;
  gap: 16rpx;
  padding: 18rpx 36rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(251, 251, 247, 0.96);
  border-top: 2rpx solid rgba(21, 23, 19, 0.12);
  backdrop-filter: blur(14rpx);
}

.review-actions .primary-button,
.review-actions .soft-button {
  height: 88rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

.warning-card {
  padding: 18rpx 20rpx;
  color: #425147;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
  background: #eef4ef;
  border: 2rpx solid rgba(21, 23, 19, 0.1);
  border-radius: 28rpx;
}

.recognizing-layer {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: grid;
  place-items: center;
  padding: 56rpx;
  background: rgba(251, 251, 247, 0.66);
  backdrop-filter: blur(16rpx);
}

.recognizing-card {
  width: 100%;
  max-width: 560rpx;
  padding: 44rpx;
  color: #151713;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 56rpx;
  box-shadow: 0 48rpx 108rpx rgba(22, 25, 18, 0.14);
}

.recognizing-top {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.recognizing-orbit {
  position: relative;
  display: grid;
  width: 128rpx;
  height: 128rpx;
  flex: none;
  place-items: center;
  border-radius: 50%;
}

.recognizing-orbit::before {
  position: absolute;
  inset: 10rpx;
  z-index: 0;
  content: "";
  background: #fff2c8;
  border-radius: 50%;
}

.recognizing-spinner {
  position: absolute;
  inset: 0;
  z-index: 1;
  width: 128rpx;
  height: 128rpx;
  animation: recognizing-orbit-spin 1.05s linear infinite;
  transform-origin: center;
}

.recognizing-mascot {
  position: relative;
  z-index: 2;
  width: 88rpx;
  height: 88rpx;
}

@keyframes recognizing-orbit-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.recognizing-copy {
  display: block;
  min-width: 0;
}

.recognizing-title {
  display: block;
  color: #151713;
  font-size: 38rpx;
  font-weight: 840;
  line-height: 1.2;
}

.recognizing-desc {
  display: block;
  margin-top: 12rpx;
  color: #6f756d;
  font-size: 24rpx;
  font-weight: 660;
  line-height: 1.45;
}

.recognizing-progress-pill {
  display: inline-block;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
  color: #ffffff;
  background: #1f6048;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.25;
}

.recognizing-steps {
  display: grid;
  gap: 16rpx;
  margin-top: 36rpx;
}

.recognizing-step {
  display: grid;
  grid-template-columns: 36rpx minmax(0, 1fr) auto;
  gap: 18rpx;
  align-items: center;
  color: #6f756d;
  font-size: 24rpx;
  font-weight: 720;
}

.recognizing-step.active {
  color: #151713;
}

.recognizing-dot {
  display: block;
  width: 16rpx;
  height: 16rpx;
  margin: 0 auto;
  background: rgba(31, 96, 72, 0.26);
  border-radius: 50%;
}

.recognizing-step.active .recognizing-dot {
  width: 20rpx;
  height: 20rpx;
  background: #1f6048;
}

.recognizing-state {
  color: #1f6048;
  font-size: 22rpx;
  font-weight: 820;
  white-space: nowrap;
}

.recognizing-hint {
  margin-top: 34rpx;
  padding: 22rpx 24rpx;
  color: #143e31;
  background: rgba(219, 233, 223, 0.56);
  border: 2rpx solid rgba(31, 96, 72, 0.1);
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}
