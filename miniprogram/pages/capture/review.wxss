.review-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  min-height: 100vh;
  padding-bottom: 196rpx;
  background:
    linear-gradient(180deg, #fff9ec 0%, #f4faee 54%, #fff7e8 100%);
}

.review-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding-top: 12rpx;
}

.review-head .pill {
  flex: none;
  margin-top: 6rpx;
}

.segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 8rpx;
  border: 2rpx solid #eadfc8;
  background: #fff0b8;
  border-radius: 28rpx;
}

.segment {
  height: 68rpx;
  color: #8a7f6e;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 68rpx;
  background: transparent;
  border-radius: 22rpx;
}

.segment.active {
  color: #ff7a59;
  background: #fffdf8;
}

.summary-panel,
.edit-panel {
  display: grid;
  gap: 16rpx;
}

.photo-stage {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 480rpx;
  overflow: hidden;
  background: #dff3df;
  border: 2rpx solid #eadfc8;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 0 #f1e4c8;
}

.plain-photo {
  width: 100%;
  height: 520rpx;
}

.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 28rpx;
}

.summary-title {
  display: block;
  color: #2f352c;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.3;
}

.quick-list {
  display: grid;
  gap: 8rpx;
}

.editor-card {
  display: block;
}

.quick-item {
  display: grid;
  grid-template-columns: 44rpx 1fr auto;
  gap: 12rpx;
  align-items: center;
  min-height: 92rpx;
  padding: 14rpx;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 26rpx;
}

.quick-index {
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 42rpx;
  text-align: center;
  background: #ff7a59;
  border-radius: 50%;
}

.quick-index.muted {
  color: #7b7465;
  background: #eef0ea;
}

.quick-copy {
  min-width: 0;
}

.quick-name {
  display: block;
  overflow: hidden;
  color: #2f352c;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.mini-tag {
  max-width: 100%;
  padding: 5rpx 10rpx;
  overflow: hidden;
  color: #725f45;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #fff0b8;
  border: 1rpx solid #ecd79a;
  border-radius: 999rpx;
}

.review-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 35;
  display: grid;
  grid-template-columns: 0.9fr 1.15fr;
  gap: 16rpx;
  padding: 18rpx 36rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 248, 0.96);
  border-top: 2rpx solid rgba(234, 223, 200, 0.9);
  backdrop-filter: blur(14rpx);
}

.review-actions .primary-button,
.review-actions .soft-button {
  height: 88rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

.review-actions .primary-button {
  box-shadow: 0 8rpx 0 #d9553a;
}

.warning-card {
  padding: 18rpx 20rpx;
  color: #775f28;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
  background: #fff2c8;
  border: 2rpx solid #ecd79a;
  border-radius: 28rpx;
}
