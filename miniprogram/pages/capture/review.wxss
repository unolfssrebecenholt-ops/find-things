.review-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  min-height: 100vh;
  padding-bottom: 196rpx;
  background:
    radial-gradient(circle at 0 0, rgba(232, 185, 93, 0.12), transparent 34%),
    #fffdf8;
}

.review-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding-top: 12rpx;
}

.review-head .pill {
  flex: none;
  margin-top: 6rpx;
}

.segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 8rpx;
  border: 1rpx solid #e4ded1;
  background: #f1eee4;
  border-radius: 8rpx;
}

.segment {
  height: 68rpx;
  color: #697366;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 68rpx;
  background: transparent;
  border-radius: 6rpx;
}

.segment.active {
  color: #2f6f4b;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(82, 72, 51, 0.1);
}

.summary-panel,
.edit-panel {
  display: grid;
  gap: 16rpx;
}

.photo-stage {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 480rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #edf6ee, #f7efe0);
  border: 1rpx solid #dfe5d9;
  border-radius: 8rpx;
}

.plain-photo {
  width: 100%;
  height: 520rpx;
}

.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid #e4ded1;
  border-radius: 8rpx;
}

.summary-title {
  display: block;
  color: #253027;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.3;
}

.quick-list {
  display: grid;
  gap: 8rpx;
}

.editor-card {
  display: block;
}

.quick-item {
  display: grid;
  grid-template-columns: 44rpx 1fr auto;
  gap: 12rpx;
  align-items: center;
  min-height: 92rpx;
  padding: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e4ded1;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 18rpx rgba(89, 79, 55, 0.05);
}

.quick-index {
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 42rpx;
  text-align: center;
  background: #2f6f4b;
  border-radius: 50%;
}

.quick-index.muted {
  color: #697366;
  background: #eef0ea;
}

.quick-copy {
  min-width: 0;
}

.quick-name {
  display: block;
  overflow: hidden;
  color: #253027;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.mini-tag {
  max-width: 100%;
  padding: 5rpx 10rpx;
  overflow: hidden;
  color: #5f695b;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #f4f7f1;
  border: 1rpx solid #e0e8dd;
  border-radius: 6rpx;
}

.review-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 35;
  display: grid;
  grid-template-columns: 0.9fr 1.15fr;
  gap: 16rpx;
  padding: 18rpx 36rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 248, 0.96);
  border-top: 1rpx solid rgba(219, 212, 197, 0.82);
  backdrop-filter: blur(14rpx);
}

.review-actions .primary-button,
.review-actions .soft-button {
  height: 88rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

.review-actions .primary-button {
  box-shadow: 0 14rpx 30rpx rgba(79, 143, 103, 0.22);
}

.warning-card {
  padding: 18rpx 20rpx;
  color: #8d2f22;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
  background: #fff0ec;
  border: 1rpx solid #f0b8aa;
  border-radius: 8rpx;
}
