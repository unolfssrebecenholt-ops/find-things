.capture-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding-bottom: 48rpx;
}

.intro {
  padding-top: 12rpx;
}

.intro .subtle {
  display: block;
  margin-top: 14rpx;
}

.capture-card {
  overflow: hidden;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 34rpx;
  box-shadow: 0 12rpx 0 #f1e4c8;
}

.capture-illustration {
  position: relative;
  height: 318rpx;
  background: #dff3df;
}

.capture-illustration::before {
  position: absolute;
  top: 34rpx;
  right: 42rpx;
  width: 154rpx;
  height: 26rpx;
  content: "";
  background: #fff0b8;
  border-radius: 999rpx;
  transform: rotate(-10deg);
}

.capture-mascot {
  position: absolute;
  top: 40rpx;
  right: 56rpx;
  z-index: 2;
  width: 118rpx;
  height: 118rpx;
}

.layer {
  position: absolute;
  border-radius: 8rpx;
}

.shelf {
  right: 34rpx;
  bottom: 72rpx;
  left: 34rpx;
  height: 3rpx;
  background: rgba(118, 104, 83, 0.2);
}

.book {
  top: 64rpx;
  left: 74rpx;
  width: 170rpx;
  height: 88rpx;
  background: #8ab7ee;
  transform: rotate(-5deg);
}

.pen {
  top: 168rpx;
  right: 88rpx;
  width: 190rpx;
  height: 20rpx;
  background: #4b493f;
  border-radius: 999rpx;
  transform: rotate(4deg);
}

.clip {
  right: 90rpx;
  bottom: 74rpx;
  width: 70rpx;
  height: 48rpx;
  border: 8rpx solid #ff7a59;
  background: transparent;
  border-radius: 999rpx;
}

.capture-copy {
  display: grid;
  gap: 8rpx;
  padding: 24rpx;
}

.capture-title {
  color: #2f352c;
  font-size: 31rpx;
  font-weight: 800;
}

.actions {
  display: grid;
  gap: 16rpx;
}

.action {
  width: 100%;
}
