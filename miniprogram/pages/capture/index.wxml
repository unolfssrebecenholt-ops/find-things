<view class="page capture-page">
  <view class="intro">
    <text class="eyebrow">第一步</text>
    <text class="page-title">拍下箱内物品</text>
    <text class="subtle">先拍箱内或抽屉内的照片，默认可保存 2 张；多角度会让搜索更准。</text>
  </view>

  <view class="capture-card">
    <view class="capture-illustration">
      <image class="capture-mascot" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
      <view class="layer shelf"></view>
      <view class="layer book"></view>
      <view class="layer pen"></view>
      <view class="layer clip"></view>
    </view>
    <view class="capture-copy">
      <text class="capture-title">给小懒一张清楚的照片</text>
      <text class="subtle">从正上方拍，物品重叠多时可以继续拍下一张。</text>
    </view>
  </view>

  <view class="actions">
    <button class="primary-button action" loading="{{choosing}}" bindtap="chooseImage">拍照或选图</button>
  </view>

</view>
