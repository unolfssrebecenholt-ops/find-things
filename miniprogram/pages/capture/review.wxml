<view class="page review-page">
  <view class="review-head">
    <view>
      <text class="eyebrow">书桌左侧抽屉</text>
      <text class="page-title">确认识别结果</text>
    </view>
    <view class="sloth-chip">
      <image mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
      <text>{{items.length}} 件</text>
    </view>
  </view>

  <view class="ratio-guide">
    <text>横过来拍更清楚</text>
    <text class="ratio-guide-strong">小懒好找</text>
    <text>竖着拍也收</text>
  </view>

  <view wx:if="{{showAiWarning}}" class="warning-card xiaolan-row">
    <image class="xiaolan-avatar small" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
    <text>{{aiStatusText}}</text>
  </view>

  <view class="summary-panel">
    <view class="photo-map ratio-landscape {{ratioClass}}">
      <image class="plain-photo" mode="aspectFit" src="{{imagePath}}"></image>
      <view class="annotation-layer">
        <view
          wx:for="{{items}}"
          wx:key="itemKey"
          wx:if="{{item.hasAnnotation}}"
          class="annotation-box"
          style="{{item.annotationStyle}}"
        >
          <text class="annotation-index">{{item.displayIndex}}</text>
        </view>
      </view>
    </view>
    <view class="summary-card">
      <view>
        <text class="summary-title">已识别 {{items.length}} 件</text>
        <text class="subtle">按标注核对名称、颜色和方位。</text>
      </view>
      <text class="pill">{{currentLabel}}</text>
    </view>
  </view>

  <view class="quick-list">
    <view wx:for="{{items}}" wx:key="itemKey" class="quick-item {{item.isExpanded ? 'expanded' : ''}}">
      <view class="quick-toolbar">
        <view class="quick-identity">
          <text class="quick-index">{{item.displayIndex}}</text>
          <text class="quick-identity-copy">小懒识别</text>
          <text class="quick-confidence">{{item.confidenceLabel}}</text>
        </view>
        <view class="quick-actions">
          <button
            wx:if="{{item.isCollapsed}}"
            class="quick-action expand-button"
            data-key="{{item.itemKey}}"
            bindtap="toggleItemExpanded"
          >展开</button>
          <button
            wx:if="{{item.isExpanded}}"
            class="quick-action delete"
            data-key="{{item.itemKey}}"
            bindtap="removeExpandedItem"
          >移除</button>
          <button
            wx:if="{{item.isExpanded}}"
            class="quick-action collapse-action"
            data-key="{{item.itemKey}}"
            bindtap="toggleItemExpanded"
          >收起</button>
        </view>
      </view>
      <view wx:if="{{item.isCollapsed}}" class="quick-summary">
        <view class="quick-copy">
          <text class="quick-name">{{item.displayName}}</text>
          <text class="subtle">{{item.displayDescription}}</text>
          <view wx:if="{{item.hasTags}}" class="quick-tags">
            <text wx:for="{{item.tagList}}" wx:for-item="tag" wx:key="*this" class="mini-tag">{{tag}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{item.isExpanded}}" class="quick-editor">
        <item-editor
          items="{{item.editorItems}}"
          hide-head="{{true}}"
          context-key="{{item.itemKey}}"
          bind:change="handleExpandedItemChange"
        ></item-editor>
      </view>
    </view>
  </view>

  <view wx:if="{{warnings.length}}" class="note-card">{{warnings[0]}}</view>

  <view class="review-actions">
    <button class="soft-button" bindtap="addNextPhoto">拍下一张</button>
    <button class="primary-button" bindtap="goNext">保存容器</button>
  </view>

  <view wx:if="{{recognizing}}" class="recognizing-layer">
    <view class="recognizing-card">
      <view class="recognizing-top">
        <view class="recognizing-orbit">
          <image class="recognizing-spinner" mode="aspectFit" src="/assets/loading-orbit-arc.svg"></image>
          <image class="recognizing-mascot" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
        </view>
        <view class="recognizing-copy">
          <text class="recognizing-title">小懒正在分析中</text>
          <text class="recognizing-desc">{{recognizingDescText}}</text>
          <text class="recognizing-progress-pill">{{recognizingProgressText}}</text>
        </view>
      </view>
      <view class="recognizing-steps">
        <view class="recognizing-step active">
          <text class="recognizing-dot"></text>
          <text>先把耐心放进口袋</text>
          <text class="recognizing-state">稳住</text>
        </view>
        <view class="recognizing-step active">
          <text class="recognizing-dot"></text>
          <text>小懒正在探头探脑</text>
          <text class="recognizing-state">看着呢</text>
        </view>
        <view class="recognizing-step">
          <text class="recognizing-dot"></text>
          <text>马上带着线索回来</text>
          <text class="recognizing-state">{{recognizingProgressStateText}}</text>
        </view>
      </view>
      <view class="recognizing-hint">{{recognizingHintText}}</view>
    </view>
  </view>
</view>
