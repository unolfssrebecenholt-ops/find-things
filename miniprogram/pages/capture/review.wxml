<view class="page review-page">
  <view class="review-head">
    <view>
      <text class="eyebrow">书桌左侧抽屉</text>
      <text class="page-title">确认识别结果</text>
    </view>
    <text class="pill">{{currentLabel}} · {{items.length}} 件</text>
  </view>

  <view class="segmented">
    <button
      class="segment {{viewMode == 'summary' ? 'active' : ''}}"
      data-mode="summary"
      bindtap="switchViewMode"
    >清单</button>
    <button
      class="segment {{viewMode == 'edit' ? 'active' : ''}}"
      data-mode="edit"
      bindtap="switchViewMode"
    >编辑</button>
  </view>

  <view wx:if="{{showAiWarning}}" class="warning-card">{{aiStatusText}}</view>

  <view wx:if="{{isSummaryMode}}" class="summary-panel">
    <view class="photo-stage">
      <image class="plain-photo" mode="aspectFit" src="{{imagePath}}"></image>
    </view>
    <view class="summary-card">
      <view>
        <text class="summary-title">已识别 {{items.length}} 件</text>
        <text class="subtle">不在图片上画框，按清单核对名称和方位，避免误导。</text>
      </view>
      <text class="pill">清单</text>
    </view>
    <view class="quick-list">
      <view wx:for="{{items}}" wx:key="tempId" class="quick-item">
        <text class="quick-index">{{item.displayIndex}}</text>
        <view class="quick-copy">
          <text class="quick-name">{{item.displayName}}</text>
          <text class="subtle">{{item.displayDescription}}</text>
          <view wx:if="{{item.hasTags}}" class="quick-tags">
            <text wx:for="{{item.tagList}}" wx:for-item="tag" wx:key="*this" class="mini-tag">{{tag}}</text>
          </view>
        </view>
        <text class="pill">{{item.confidenceLabel}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{isEditMode}}" class="edit-panel">
    <view class="editor-card">
      <item-editor items="{{items}}" bind:change="handleItemsChange"></item-editor>
    </view>
  </view>

  <view wx:if="{{warnings.length}}" class="note-card">{{warnings[0]}}</view>

  <view class="review-actions">
    <button class="soft-button" bindtap="addNextPhoto">拍下一张</button>
    <button class="primary-button" bindtap="goNext">下一步：拍容器</button>
  </view>
</view>
