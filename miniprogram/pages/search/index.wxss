.search-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-top: 42rpx;
}

.page-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding: 6rpx 4rpx 2rpx;
}

.search-heading {
  min-width: 0;
  flex: 1;
}

.search-title {
  font-size: 50rpx;
  line-height: 1.14;
}

.search-box {
  display: grid;
  grid-template-columns: 38rpx minmax(0, 1fr);
  gap: 14rpx;
  align-items: center;
  min-height: 96rpx;
  padding: 10rpx 10rpx 10rpx 22rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 46rpx rgba(22, 25, 18, 0.07);
}

.search-mark {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #1f6048;
  border-radius: 50%;
}

.search-mark::after {
  position: absolute;
  right: -10rpx;
  bottom: -8rpx;
  width: 15rpx;
  height: 5rpx;
  content: "";
  background: #1f6048;
  border-radius: 999rpx;
  transform: rotate(45deg);
}

.search-input {
  min-width: 0;
  height: 76rpx;
  color: #151713;
  font-size: 30rpx;
  font-weight: 650;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 2rpx 0 4rpx;
}

.chip {
  min-height: 58rpx;
  padding: 12rpx 20rpx;
  color: #425147;
  font-size: 24rpx;
  font-weight: 750;
  line-height: 32rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 999rpx;
}

.result-stack {
  display: grid;
  gap: 18rpx;
}

.search-page .section-row {
  margin-top: 18rpx;
}

.search-page .empty-state {
  margin-top: 4rpx;
}
