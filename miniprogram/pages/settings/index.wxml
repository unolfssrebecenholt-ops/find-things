<view class="page settings-page">
  <text class="page-title settings-title">设置</text>

  <view class="settings-card">
    <view class="settings-hero xiaolan-row">
      <image class="xiaolan-avatar" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
      <view class="xiaolan-copy">
        <text class="card-title">小懒识别服务</text>
        <text class="subtle">小懒会把照片分析成可搜索的物品清单。识别请求统一通过云函数和中转站配置处理。</text>
      </view>
    </view>

    <view class="field">
      <text class="label">调用方式</text>
      <view class="input readonly">{{transport == 'cloud' ? '云函数' : '本地直连'}}</view>
    </view>

    <view class="field">
      <text class="label">模型</text>
      <view class="input readonly">{{model}}</view>
    </view>

    <view class="field">
      <text class="label">中转站</text>
      <view class="input readonly">{{relayCount}} 个可用：{{relayNames}}</view>
    </view>

    <view class="settings-actions"></view>
  </view>
</view>
