.settings-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.settings-title {
  margin-top: 4rpx;
}

.settings-card {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding: 26rpx;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 34rpx;
  box-shadow: 0 10rpx 0 #f1e4c8;
}

.settings-hero {
  align-items: flex-start;
  padding-bottom: 4rpx;
}

.card-title {
  color: #2f352c;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.label {
  color: #725f45;
  font-size: 25rpx;
  font-weight: 700;
}

.input {
  box-sizing: border-box;
  height: 76rpx;
  padding: 0 18rpx;
  color: #2f352c;
  font-size: 27rpx;
  line-height: 76rpx;
  background: #fff9ee;
  border: 2rpx solid #eadfc8;
  border-radius: 22rpx;
}

.input.readonly {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.segmented-inline {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.segment {
  height: 68rpx;
  color: #725f45;
  font-size: 25rpx;
  line-height: 68rpx;
  background: #fff9ee;
  border: 2rpx solid #eadfc8;
  border-radius: 22rpx;
}

.segment.active {
  color: #ffffff;
  background: #ff7a59;
  border-color: #ff7a59;
}

.settings-actions {
  display: none;
}
