<view class="page detail-page" wx:if="{{hasContainer}}">
  <view class="detail-head">
    <view>
      <text class="eyebrow">{{container.displayLocation}}</text>
      <text class="page-title">{{container.name}}</text>
    </view>
    <view class="danger-action" bindtap="deleteContainer">删除</view>
  </view>

  <view class="detail-hero">
    <view class="stats-row">
      <view class="stat">
        <text class="stat-value">{{container.itemCount}}</text>
        <text class="subtle">件物品</text>
      </view>
      <view class="stat">
        <text class="stat-value">{{contentImages.length}}/{{photoLimit}}</text>
        <text class="subtle">箱内照片</text>
      </view>
      <view class="stat">
        <text class="stat-value">今天</text>
        <text class="subtle">更新</text>
      </view>
    </view>
  </view>

  <view class="section-row">
    <text class="section-heading">箱内照片</text>
    <text class="text-link" bindtap="addContentPhoto">添加照片</text>
  </view>

  <view wx:if="{{hasContentImages}}" class="photo-carousel photo-card">
    <view class="carousel-head">
      <text class="carousel-title">当前箱内照片 <text class="pill">{{currentImageIndex + 1}}/{{contentImages.length}}</text></text>
      <text class="pill">多拍更好找</text>
    </view>

    <swiper
      class="photo-swiper"
      current="{{currentImageIndex}}"
      duration="220"
      bindchange="onSwiperChange"
    >
      <swiper-item wx:for="{{contentImages}}" wx:key="imageId">
        <annotated-image
          image-src="{{item.displaySrc}}"
          items="{{item.items}}"
          compact="{{true}}"
          data-index="{{index}}"
          bind:imageerror="handleContentImageError"
        ></annotated-image>
      </swiper-item>
    </swiper>

    <view class="carousel-indicator">
      <view
        wx:for="{{contentImages}}"
        wx:key="imageId"
        class="carousel-dot {{index == currentImageIndex ? 'active' : ''}}"
      ></view>
      <text class="carousel-count">{{currentImageIndex + 1}} / {{contentImages.length}}</text>
    </view>

    <view class="carousel-actions">
      <button class="mini-button" bindtap="reRecognizeCurrent">重新识别这张</button>
      <button class="mini-button secondary" bindtap="addContentPhoto">{{addPhotoLabel}}</button>
    </view>
  </view>
  <view wx:if="{{showContentEmpty}}" class="empty-state with-xiaolan">
    <view class="xiaolan-row">
      <image class="xiaolan-avatar" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
      <view class="xiaolan-copy">
        <text class="xiaolan-name">小懒还没看到箱子里面</text>
        <text>添加照片后，可以在这里左右滑动查看。</text>
      </view>
    </view>
  </view>

  <view class="section-row">
    <text class="section-heading">物品</text>
    <text class="text-link" bindtap="addManualItem">添加</text>
  </view>
  <view wx:if="{{hasItems}}" class="inventory-list">
    <view wx:for="{{items}}" wx:key="itemKey" class="inventory-item {{item.stateClass}}">
      <view class="inventory-toolbar">
        <view class="inventory-identity">
          <text class="inventory-index">{{item.displayIndex}}</text>
          <view class="inventory-copy">
            <text class="inventory-name">{{item.displayName}}</text>
            <text class="inventory-source">{{item.sourceLabel}}</text>
          </view>
        </view>
        <view class="inventory-actions">
          <button
            wx:if="{{item.showExpandAction}}"
            class="inventory-action expand"
            data-key="{{item.itemKey}}"
            bindtap="toggleItemExpanded"
          >展开</button>
          <button
            wx:if="{{item.showRemoveAction}}"
            class="inventory-action remove"
            data-key="{{item.itemKey}}"
            bindtap="removeExpandedItem"
          >移除</button>
          <button
            wx:if="{{item.showCollapseAction}}"
            class="inventory-action collapse"
            data-key="{{item.itemKey}}"
            bindtap="toggleItemExpanded"
          >收起</button>
        </view>
      </view>

      <view wx:if="{{item.isCollapsed}}" class="inventory-summary">
        <text wx:if="{{item.hasExpiry}}" class="expiry-badge {{item.expiryState}}">{{item.expiryLabel}}</text>
        <text class="subtle">{{item.displayDescription}}</text>
        <view wx:if="{{item.hasTags}}" class="inventory-tags">
          <text wx:for="{{item.tagList}}" wx:for-item="tag" wx:key="*this" class="mini-tag">{{tag}}</text>
        </view>
      </view>

      <view wx:if="{{item.isExpanded}}" class="inventory-editor">
        <item-editor
          items="{{item.editorItems}}"
          hide-head="{{true}}"
          context-key="{{item.itemKey}}"
          bind:change="handleExpandedItemChange"
        ></item-editor>
      </view>
    </view>
  </view>
  <view wx:if="{{showItemsEmpty}}" class="empty-state with-xiaolan">
    <view class="xiaolan-row">
      <image class="xiaolan-avatar" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
      <view class="xiaolan-copy">
        <text class="xiaolan-name">清单还空着</text>
        <text>可以手动添加，也可以先拍一张箱内照片。</text>
      </view>
    </view>
  </view>
  <view wx:if="{{showRecoverInventory}}" class="empty-state with-xiaolan inventory-recover">
    <view class="xiaolan-row">
      <image class="xiaolan-avatar" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
      <view class="xiaolan-copy">
        <text class="xiaolan-name">清单明细没同步回来</text>
        <text>{{missingInventoryText}}</text>
      </view>
    </view>
    <button wx:if="{{canRecoverInventory}}" class="empty-action recover-action" bindtap="recoverInventoryFromPhoto">从当前照片恢复清单</button>
  </view>

  <view class="note-card quiet-note">{{inventoryStatusText}}。搜索会同时看名称、可见文字和关键特征。</view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goHome">
      <view class="nav-icon"></view>
      <text>首页</text>
    </view>
    <view class="nav-item" bindtap="goSearch">
      <view class="nav-icon search"></view>
      <text>找东西</text>
    </view>
    <view class="nav-item active">
      <view class="nav-icon box"></view>
      <text>容器</text>
    </view>
  </view>

  <view wx:if="{{recognizing}}" class="recognizing-layer">
    <view class="recognizing-card">
      <view class="recognizing-top">
        <view class="recognizing-orbit">
          <image class="recognizing-spinner" mode="aspectFit" src="/assets/loading-orbit-arc.svg"></image>
          <image class="recognizing-mascot" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
        </view>
        <view class="recognizing-copy">
          <text class="recognizing-title">小懒正在分析中</text>
          <text class="recognizing-desc">{{recognizingDescText}}</text>
          <text class="recognizing-progress-pill">{{recognizingProgressText}}</text>
        </view>
      </view>
      <view class="recognizing-steps">
        <view class="recognizing-step active">
          <text class="recognizing-dot"></text>
          <text>先把耐心放进口袋</text>
          <text class="recognizing-state">稳住</text>
        </view>
        <view class="recognizing-step active">
          <text class="recognizing-dot"></text>
          <text>小懒正在探头探脑</text>
          <text class="recognizing-state">看着呢</text>
        </view>
        <view class="recognizing-step">
          <text class="recognizing-dot"></text>
          <text>马上带着线索回来</text>
          <text class="recognizing-state">{{recognizingProgressStateText}}</text>
        </view>
      </view>
      <view class="recognizing-hint">{{recognizingHintText}}</view>
    </view>
  </view>
</view>
<view class="page" wx:if="{{showMissingContainer}}">
  <view class="empty-state with-xiaolan">
    <view class="xiaolan-row">
      <image class="xiaolan-avatar" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
      <view class="xiaolan-copy">
        <text class="xiaolan-name">小懒没找到这个容器</text>
        <text>可能已经删除，或者链接里的容器信息不完整。</text>
      </view>
    </view>
  </view>
</view>
