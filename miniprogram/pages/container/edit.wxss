.edit-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: 190rpx;
  background: #fff7e8;
}

.edit-head {
  display: grid;
  gap: 8rpx;
  padding-top: 8rpx;
}

.form-section {
  display: grid;
  gap: 16rpx;
  padding: 20rpx;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 30rpx;
  box-shadow: 0 8rpx 0 #f1e4c8;
}

.field-group {
  display: grid;
  gap: 10rpx;
}

.field-label {
  color: #2f352c;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.25;
}

.field {
  height: 82rpx;
  padding: 0 20rpx;
  color: #2f352c;
  font-size: 28rpx;
  font-weight: 650;
  background: #fff9ee;
  border: 2rpx solid #eadfc8;
  border-radius: 22rpx;
}

.compact-row {
  margin: 18rpx 0 0;
}

.cover-panel {
  display: grid;
  gap: 14rpx;
  overflow: hidden;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 30rpx;
  box-shadow: 0 8rpx 0 #f1e4c8;
}

.cover {
  width: 100%;
  height: 382rpx;
  background: #dff3df;
}

.cover-placeholder {
  display: grid;
  gap: 8rpx;
  min-height: 382rpx;
  align-content: center;
  padding: 26rpx;
  background:
    linear-gradient(135deg, rgba(255, 253, 248, 0.55), rgba(255, 240, 184, 0.18)),
    #dff3df;
}

.cover-title {
  color: #2f352c;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1.3;
}

.cover-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 12rpx;
  padding: 0 16rpx 16rpx;
}

.cover-actions .action {
  height: 76rpx;
  font-size: 26rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.photo-summary-item {
  overflow: hidden;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 26rpx;
}

.photo-thumb {
  width: 100%;
  height: 150rpx;
  background: #dff3df;
}

.photo-copy {
  display: grid;
  gap: 4rpx;
  padding: 14rpx;
}

.photo-summary-name {
  color: #ff7a59;
  font-size: 26rpx;
  font-weight: 800;
}

.photo-summary-meta {
  color: #7b7465;
  font-size: 23rpx;
}

.item-preview {
  display: grid;
  gap: 10rpx;
}

.item-row {
  display: grid;
  grid-template-columns: 44rpx minmax(0, 1fr);
  gap: 12rpx;
  align-items: center;
  min-height: 70rpx;
  padding: 12rpx 16rpx;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 24rpx;
}

.item-index {
  width: 40rpx;
  height: 40rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 40rpx;
  text-align: center;
  background: #ff7a59;
  border-radius: 50%;
}

.item-name {
  min-width: 0;
  overflow: hidden;
  color: #2f352c;
  font-size: 27rpx;
  font-weight: 780;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.more-row {
  padding: 16rpx 18rpx;
  color: #7b7465;
  font-size: 25rpx;
  text-align: center;
  background: #fff0b8;
  border-radius: 22rpx;
}

.save-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 35;
  display: grid;
  grid-template-columns: 0.9fr 1.15fr;
  gap: 16rpx;
  padding: 18rpx 36rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 248, 0.96);
  border-top: 2rpx solid rgba(234, 223, 200, 0.9);
  backdrop-filter: blur(14rpx);
}

.save-actions .primary-button,
.save-actions .soft-button {
  height: 88rpx;
  font-size: 28rpx;
  white-space: nowrap;
}
