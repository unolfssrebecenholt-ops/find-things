.edit-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: 190rpx;
  background:
    linear-gradient(90deg, rgba(21, 23, 19, 0.035) 1px, transparent 1px) 0 0 / 72rpx 72rpx,
    linear-gradient(180deg, #f7f6f1 0%, #f3f2ed 100%);
}

.page-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.title-stack {
  display: grid;
  min-width: 0;
  gap: 8rpx;
}

.sloth-chip {
  display: inline-flex;
  align-items: center;
  flex: none;
  gap: 12rpx;
  max-width: 190rpx;
  height: 72rpx;
  padding: 8rpx 18rpx 8rpx 8rpx;
  color: #143e31;
  background: rgba(219, 233, 223, 0.78);
  border: 2rpx solid rgba(31, 96, 72, 0.16);
  border-radius: 999rpx;
}

.sloth-chip image {
  width: 56rpx;
  height: 56rpx;
  flex: none;
  border-radius: 50%;
}

.sloth-chip text {
  min-width: 0;
  overflow: hidden;
  font-size: 23rpx;
  font-weight: 780;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-panel {
  display: grid;
  gap: 18rpx;
  padding: 20rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 28rpx;
}

.field-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.08fr) minmax(180rpx, 0.92fr);
  gap: 14rpx;
  align-items: start;
}

.field-group {
  display: grid;
  min-width: 0;
  gap: 10rpx;
}

.field-label {
  color: #6f756d;
  font-size: 23rpx;
  font-weight: 760;
  line-height: 1.25;
}

.field {
  width: 100%;
  height: 76rpx;
  min-width: 0;
  padding: 0 18rpx;
  color: #151713;
  font-size: 27rpx;
  font-weight: 680;
  line-height: 76rpx;
  background: #ffffff;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 18rpx;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  min-width: 0;
  min-height: 44rpx;
  padding: 6rpx 16rpx;
  color: #143e31;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.2;
  background: #dbe9df;
  border: 1rpx solid rgba(31, 96, 72, 0.12);
  border-radius: 999rpx;
}

.photo-section {
  display: grid;
  gap: 0;
}

.compact-row {
  margin: 18rpx 2rpx 14rpx;
}

.adaptive-frame {
  position: relative;
  display: grid;
  overflow: hidden;
  background:
    linear-gradient(90deg, rgba(21, 23, 19, 0.045) 1px, transparent 1px) 0 0 / 72rpx 72rpx,
    linear-gradient(0deg, rgba(21, 23, 19, 0.045) 1px, transparent 1px) 0 0 / 72rpx 72rpx,
    #e4eee7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 28rpx;
}

.adaptive-frame::after {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  z-index: 3;
  padding: 6rpx 12rpx;
  color: #1f6048;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  content: attr(data-ratio);
  background: rgba(251, 251, 247, 0.88);
  border: 1rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 999rpx;
}

.ratio-landscape {
  aspect-ratio: 16 / 9;
}

.ratio-portrait {
  width: 58%;
  aspect-ratio: 9 / 16;
  justify-self: center;
}

.ratio-square {
  aspect-ratio: 1 / 1;
}

.outside-frame {
  min-height: 0;
}

.outside-frame.ratio-square {
  width: 74%;
  justify-self: center;
}

.cover {
  width: 100%;
  height: 100%;
  min-height: 0;
  background: #dbe9df;
}

.cover-placeholder {
  display: grid;
  height: 100%;
  min-height: 0;
  align-content: center;
  gap: 10rpx;
  padding: 28rpx;
}

.photo-caption {
  display: block;
  min-width: 0;
  overflow: hidden;
  color: #151713;
  font-size: 28rpx;
  font-weight: 830;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cover-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 14rpx;
}

.cover-actions .action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 86rpx;
  min-width: 0;
  padding: 0 20rpx;
  overflow: hidden;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: normal;
  border: 0;
  border-radius: 999rpx;
}

.inside-carousel {
  display: grid;
  gap: 14rpx;
  padding: 14rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 46rpx rgba(22, 25, 18, 0.07);
}

.inside-swiper {
  height: 330rpx;
  overflow: hidden;
  border-radius: 24rpx;
}

.inside-frame {
  width: 100%;
  height: 330rpx;
  min-height: 330rpx;
  border-radius: 24rpx;
}

.inside-frame.ratio-portrait {
  width: 100%;
  aspect-ratio: auto;
}

.inside-photo {
  width: 100%;
  height: 100%;
  min-height: 330rpx;
}

.inside-carousel-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 34rpx;
  padding: 0 4rpx;
}

.carousel-dots {
  display: flex;
  align-items: center;
  gap: 9rpx;
  min-width: 0;
}

.carousel-dot {
  flex: none;
  width: 12rpx;
  height: 12rpx;
  background: #a9c8b5;
  border-radius: 999rpx;
  transition: width 180ms ease, background 180ms ease;
}

.carousel-dot.active {
  width: 42rpx;
  background: #1f6048;
}

.carousel-count {
  flex: none;
  color: #6f756d;
  font-size: 23rpx;
  font-weight: 760;
  line-height: 1.2;
}

.item-preview {
  display: grid;
  gap: 10rpx;
}

.item-row {
  display: grid;
  grid-template-columns: 44rpx minmax(0, 1fr);
  gap: 12rpx;
  align-items: center;
  min-height: 70rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 22rpx;
}

.item-index {
  width: 40rpx;
  height: 40rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 40rpx;
  text-align: center;
  background: #1f6048;
  border-radius: 50%;
}

.item-name {
  min-width: 0;
  overflow: hidden;
  color: #151713;
  font-size: 27rpx;
  font-weight: 780;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.more-row {
  padding: 16rpx 18rpx;
  color: #6f756d;
  font-size: 25rpx;
  text-align: center;
  background: #dbe9df;
  border: 1rpx solid rgba(31, 96, 72, 0.12);
  border-radius: 22rpx;
}

.save-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 35;
  display: grid;
  grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
  gap: 14rpx;
  align-items: center;
  padding: 18rpx 36rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(251, 251, 247, 0.94);
  border-top: 2rpx solid rgba(21, 23, 19, 0.12);
  backdrop-filter: blur(18rpx);
}

.save-actions .primary-button,
.save-actions .soft-button {
  height: 86rpx;
  padding: 0 18rpx;
  overflow: hidden;
  font-size: 27rpx;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: normal;
  border-radius: 999rpx;
}

@media (max-width: 360px) {
  .field-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .cover-actions,
  .save-actions {
    grid-template-columns: minmax(0, 1fr);
  }
}
