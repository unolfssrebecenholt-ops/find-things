.edit-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: 48rpx;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.field {
  height: 82rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #ffffff;
  border: 1rpx solid #e1dbd0;
  border-radius: 8rpx;
}

.cover {
  width: 100%;
  height: 360rpx;
  background: #e8e0d4;
  border-radius: 8rpx;
}

.photo-summary {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.photo-summary-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx;
  background: #fffdf8;
  border: 1rpx solid #d9e6d8;
  border-radius: 8rpx;
}

.photo-summary-name {
  color: #2f6f4c;
  font-size: 27rpx;
  font-weight: 700;
}

.photo-summary-meta {
  color: #6b7280;
  font-size: 23rpx;
}

.action,
.save {
  height: 88rpx;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.item-row {
  padding: 16rpx 18rpx;
  font-size: 27rpx;
  background: #ffffff;
  border: 1rpx solid #e1dbd0;
  border-radius: 8rpx;
}
