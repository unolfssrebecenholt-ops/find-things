<view class="page container-list-page">
  <view class="list-head">
    <view class="list-title-copy">
      <text class="eyebrow">全部容器</text>
      <text class="page-title">家里的东西，都在这里</text>
    </view>
    <view class="page-actions">
      <button class="manage-toggle {{manageButtonClass}}" bindtap="toggleManageMode">{{manageLabel}}</button>
      <button class="add-container" bindtap="goCapture">+</button>
    </view>
  </view>

  <view class="list-toolbar">
    <view class="compact-search">
      <view class="search-mark"></view>
      <input
        class="search-input"
        placeholder="搜索容器或位置"
        value="{{query}}"
        bindinput="inputQuery"
      />
    </view>
    <view class="compact-filter" aria-hidden="true">⌄</view>
  </view>

  <view class="library-summary">
    <view class="summary-tile">
      <text class="summary-value">{{summary.containerCount}}</text>
      <text class="subtle">个容器已保存</text>
    </view>
    <view class="summary-tile">
      <text class="summary-value">{{summary.itemCount}}</text>
      <text class="subtle">件物品可搜索</text>
    </view>
  </view>

  <view wx:if="{{hasContainers}}" class="section-row">
    <text class="section-title">最近更新</text>
    <text class="text-link">按时间</text>
  </view>

  <view wx:if="{{hasContainers}}" class="container-stack container-list">
    <view
      wx:for="{{containers}}"
      wx:key="_id"
      class="container-row featured {{rowModeClass}}"
      bindtap="openContainer"
      data-id="{{item._id}}"
    >
      <view
        wx:if="{{isManaging}}"
        class="select-dot {{item.selectClass}}"
        catchtap="toggleSelect"
        data-id="{{item._id}}"
      ></view>
      <view class="container-photo">
        <image wx:if="{{item.coverPhoto}}" mode="aspectFill" src="{{item.coverPhoto}}"></image>
        <view wx:if="{{item.showPlaceholder}}" class="photo-placeholder">
          <view class="placeholder-line wide"></view>
          <view class="placeholder-line"></view>
        </view>
      </view>
      <view class="container-body">
        <view>
          <text class="container-name">{{item.name}}</text>
          <text class="subtle">{{item.displaySubtitle}}</text>
        </view>
        <view class="container-meta-line">
          <text class="meta-pill">{{item.statusPill}}</text>
          <text class="meta-pill">{{item.imageCount}} 张照片</text>
        </view>
      </view>
      <view
        wx:if="{{showRowMoreActions}}"
        class="more-action"
        catchtap="showContainerActions"
        data-id="{{item._id}}"
        data-name="{{item.name}}"
        aria-label="更多操作"
      >
        <view class="more-dot"></view>
        <view class="more-dot"></view>
        <view class="more-dot"></view>
      </view>
      <button
        wx:if="{{isManaging}}"
        class="row-delete"
        catchtap="confirmDeleteFromRow"
        data-id="{{item._id}}"
        data-name="{{item.name}}"
      >删除</button>
    </view>
  </view>

  <view wx:if="{{showEmpty}}" class="empty-state with-xiaolan">
    <view class="xiaolan-row">
      <image class="xiaolan-avatar" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
      <view class="xiaolan-copy">
        <text class="xiaolan-name">小懒还没有容器记录</text>
        <text>先拍一箱，保存后会出现在这里。</text>
      </view>
    </view>
    <button class="empty-action" bindtap="goCapture">拍照整理</button>
  </view>

  <view wx:if="{{showBatchBar}}" class="batch-bar">
    <view class="batch-copy">
      <text class="batch-title">已选 {{selectedCount}} 个容器</text>
      <text class="batch-subcopy">删掉后，小懒也会忘记里面的物品</text>
    </view>
    <button class="batch-delete" bindtap="confirmBatchDelete">批量删除</button>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goHome">
      <view class="nav-icon"></view>
      <text>首页</text>
    </view>
    <view class="nav-item" bindtap="goSearch">
      <view class="nav-icon search"></view>
      <text>找东西</text>
    </view>
    <view class="nav-item active">
      <view class="nav-icon box"></view>
      <text>容器</text>
    </view>
  </view>
</view>
