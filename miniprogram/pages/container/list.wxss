.container-list-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-top: 42rpx;
  padding-bottom: 360rpx;
  background:
    linear-gradient(90deg, rgba(21, 23, 19, 0.035) 1px, transparent 1px) 0 0 / 72rpx 72rpx,
    linear-gradient(180deg, #f7f6f1 0%, #f3f2ed 100%);
}

.list-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: flex-start;
  gap: 18rpx;
  padding: 6rpx 4rpx 2rpx;
}

.list-title-copy {
  min-width: 0;
}

.page-actions {
  display: flex;
  flex: none;
  min-width: 0;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.manage-toggle {
  display: inline-flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 100rpx;
  height: 84rpx;
  padding: 0 30rpx;
  color: #1f6048;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 84rpx;
  background: #dbe9df;
  border-radius: 999rpx;
}

.manage-toggle.active {
  color: #fff;
  background: #1f6048;
}

.add-container {
  display: grid;
  flex: 0 0 84rpx;
  width: 84rpx;
  min-width: 84rpx;
  max-width: 84rpx;
  height: 84rpx;
  padding: 0;
  place-items: center;
  color: #1f6048;
  font-size: 40rpx;
  font-weight: 520;
  line-height: 1;
  background: rgba(255, 255, 255, 0.74);
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 50%;
}

.list-toolbar {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 92rpx;
  gap: 20rpx;
  align-items: center;
  margin: 8rpx 0 32rpx;
}

.compact-search {
  display: grid;
  grid-template-columns: 44rpx minmax(0, 1fr);
  gap: 20rpx;
  align-items: center;
  height: 92rpx;
  padding: 0 26rpx;
  color: #6f756d;
  background: rgba(255, 255, 255, 0.74);
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 999rpx;
}

.compact-filter {
  display: grid;
  width: 92rpx;
  height: 92rpx;
  place-items: center;
  color: #1f6048;
  font-size: 40rpx;
  font-weight: 520;
  line-height: 1;
  background: rgba(255, 255, 255, 0.74);
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 50%;
}

.search-mark {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  border: 4rpx solid #1f6048;
  border-radius: 50%;
}

.search-mark::after {
  position: absolute;
  right: -10rpx;
  bottom: -8rpx;
  width: 15rpx;
  height: 5rpx;
  content: "";
  background: #1f6048;
  border-radius: 999rpx;
  transform: rotate(45deg);
}

.search-input {
  min-width: 0;
  height: 72rpx;
  color: #6f756d;
  font-size: 26rpx;
  font-weight: 700;
}

.library-summary {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.summary-tile {
  display: grid;
  gap: 4rpx;
  min-width: 0;
  min-height: 172rpx;
  padding: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7f7f2 100%);
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 44rpx;
}

.summary-tile .subtle {
  margin-top: 16rpx;
  font-size: 24rpx;
  font-weight: 690;
  line-height: 1.35;
}

.summary-value {
  min-width: 0;
  overflow: hidden;
  color: #151713;
  font-size: 50rpx;
  font-weight: 850;
  line-height: 1.05;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 20rpx 4rpx 4rpx;
}

.section-title {
  color: #151713;
  font-size: 34rpx;
  font-weight: 820;
  line-height: 1.2;
}

.text-link {
  color: #1f6048;
  font-size: 24rpx;
  font-weight: 760;
  line-height: 1.3;
}

.container-stack {
  display: grid;
  gap: 20rpx;
}

.container-row {
  position: relative;
  display: grid;
  grid-template-columns: 220rpx minmax(0, 1fr) 52rpx;
  align-items: center;
  gap: 18rpx;
  min-height: 152rpx;
  padding: 14rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 44rpx;
}

.container-row.featured {
  grid-template-columns: 208rpx minmax(0, 1fr) auto;
  align-items: stretch;
  min-height: 252rpx;
  padding: 20rpx;
}

.container-row.featured .container-photo {
  height: 208rpx;
}

.manage-row {
  transition: transform 0.16s ease;
}

.container-list-page .manage-row {
  grid-template-columns: 44rpx 156rpx minmax(0, 1fr) 112rpx;
  gap: 24rpx;
  align-items: center;
  min-height: 212rpx;
}

.container-list-page .manage-row .container-photo {
  height: 156rpx;
  border-radius: 32rpx;
}

.select-dot {
  position: relative;
  display: block;
  align-self: center;
  justify-self: center;
  width: 44rpx;
  height: 44rpx;
  background: rgba(251, 251, 247, 0.9);
  border: 4rpx solid rgba(31, 96, 72, 0.36);
  border-radius: 50%;
}

.select-dot.selected {
  background: #1f6048;
  border-color: #1f6048;
}

.select-dot.selected::after {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 18rpx;
  height: 10rpx;
  content: "";
  border-bottom: 4rpx solid #fff;
  border-left: 4rpx solid #fff;
  transform: rotate(-45deg);
}

.container-photo {
  position: relative;
  width: 100%;
  height: 124rpx;
  overflow: hidden;
  background: #dbe9df;
  border-radius: 22rpx;
}

.container-photo image {
  width: 100%;
  height: 100%;
}

.photo-placeholder {
  position: relative;
  width: 100%;
  height: 100%;
}

.placeholder-line {
  position: absolute;
  left: 28rpx;
  bottom: 42rpx;
  width: 78rpx;
  height: 16rpx;
  background: rgba(31, 96, 72, 0.26);
  border-radius: 6rpx;
}

.placeholder-line.wide {
  bottom: 72rpx;
  width: 118rpx;
  background: rgba(251, 251, 247, 0.72);
  box-shadow: inset 0 0 0 1rpx rgba(21, 23, 19, 0.08);
}

.container-body {
  display: grid;
  min-width: 0;
  align-content: center;
  gap: 14rpx;
  padding-right: 0;
}

.container-name {
  min-width: 0;
  overflow: hidden;
  color: #151713;
  font-size: 31rpx;
  font-weight: 850;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.container-meta-line {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 42rpx;
  padding: 6rpx 14rpx;
  color: #1f6048;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
  background: #dbe9df;
  border: 1rpx solid rgba(21, 23, 19, 0.08);
  border-radius: 999rpx;
}

.more-action {
  position: static;
  align-self: center;
  justify-self: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  width: 48rpx;
  height: 44rpx;
  background: transparent;
  border-radius: 6rpx;
}

.more-dot {
  width: 7rpx;
  height: 7rpx;
  background: #8b9288;
  border-radius: 50%;
}

.row-delete {
  display: inline-flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  height: 64rpx;
  padding: 0;
  color: #9f3d32;
  font-size: 22rpx;
  font-weight: 820;
  line-height: 64rpx;
  white-space: nowrap;
  background: #f7e5df;
  border-radius: 999rpx;
}

.batch-bar {
  position: fixed;
  right: max(44rpx, env(safe-area-inset-right));
  bottom: 150rpx;
  left: max(44rpx, env(safe-area-inset-left));
  z-index: 28;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 20rpx;
  align-items: center;
  min-height: 96rpx;
  padding: 20rpx 20rpx 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 44rpx;
  box-shadow: 0 36rpx 84rpx rgba(22, 25, 18, 0.12);
  backdrop-filter: blur(16rpx);
}

.batch-copy {
  display: grid;
  gap: 4rpx;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.batch-title {
  overflow: hidden;
  color: #151713;
  font-size: 26rpx;
  font-weight: 860;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.batch-subcopy {
  overflow: hidden;
  color: #6f756d;
  font-size: 24rpx;
  font-weight: 720;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.batch-delete {
  width: auto;
  min-width: 0;
  max-width: 200rpx;
  height: 80rpx;
  padding: 0 30rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 850;
  line-height: 80rpx;
  background: #9f3d32;
  border-radius: 999rpx;
}
