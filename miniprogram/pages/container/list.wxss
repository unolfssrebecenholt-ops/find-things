.container-list-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-top: 42rpx;
}

.list-head {
  display: grid;
  gap: 8rpx;
  padding: 6rpx 4rpx 2rpx;
}

.container-stack {
  display: grid;
  gap: 14rpx;
  margin-top: 8rpx;
}

.container-row {
  position: relative;
  display: grid;
  grid-template-columns: 220rpx minmax(0, 1fr);
  align-items: center;
  gap: 18rpx;
  min-height: 152rpx;
  padding: 14rpx;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 30rpx;
  box-shadow: 0 8rpx 0 #f1e4c8;
}

.container-photo {
  position: relative;
  width: 100%;
  height: 124rpx;
  overflow: hidden;
  background: #dff3df;
  border-radius: 22rpx;
}

.container-photo image {
  width: 100%;
  height: 100%;
}

.photo-placeholder {
  position: relative;
  width: 100%;
  height: 100%;
}

.placeholder-line {
  position: absolute;
  left: 28rpx;
  bottom: 42rpx;
  width: 78rpx;
  height: 16rpx;
  background: rgba(255, 122, 89, 0.42);
  border-radius: 6rpx;
}

.placeholder-line.wide {
  bottom: 72rpx;
  width: 118rpx;
  background: rgba(255, 253, 248, 0.72);
  box-shadow: inset 0 0 0 1rpx rgba(117, 100, 68, 0.08);
}

.container-copy {
  display: grid;
  min-width: 0;
  align-content: center;
  gap: 8rpx;
  padding-right: 58rpx;
}

.container-name {
  min-width: 0;
  overflow: hidden;
  color: #2f352c;
  font-size: 31rpx;
  font-weight: 850;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 2rpx;
}

.more-action {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  width: 48rpx;
  height: 44rpx;
  background: transparent;
  border-radius: 6rpx;
}

.more-dot {
  width: 7rpx;
  height: 7rpx;
  background: #b1a38d;
  border-radius: 50%;
}
