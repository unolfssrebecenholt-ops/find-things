.detail-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-top: 42rpx;
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 6rpx 4rpx 2rpx;
}

.danger-action {
  display: flex;
  flex: 0 0 96rpx;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  min-width: 96rpx;
  max-width: 96rpx;
  height: 64rpx;
  padding: 0;
  color: #a33b2f;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
  background: #f4e5df;
  border: 1rpx solid rgba(163, 59, 47, 0.18);
  border-radius: 18rpx;
}

.detail-hero {
  display: grid;
  gap: 16rpx;
}

.cover-photo {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(251, 251, 247, 0.58), rgba(219, 233, 223, 0.24)),
    #dbe9df;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 30rpx;
  box-shadow: 0 22rpx 58rpx rgba(22, 25, 18, 0.08);
}

.cover-photo image {
  width: 100%;
  height: 100%;
}

.cover-label {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 2;
  padding: 8rpx 14rpx;
  color: #143e31;
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(251, 251, 247, 0.9);
  border-radius: 999rpx;
}

.cover-placeholder {
  position: absolute;
  inset: 0;
  display: block;
  height: 100%;
}

.cover-box-line {
  position: absolute;
  right: 68rpx;
  bottom: 142rpx;
  left: 68rpx;
  height: 4rpx;
  background: rgba(31, 96, 72, 0.2);
}

.cover-box-shape {
  position: absolute;
  right: 68rpx;
  bottom: 58rpx;
  left: 68rpx;
  height: 172rpx;
  background: rgba(251, 251, 247, 0.42);
  border: 4rpx solid rgba(31, 96, 72, 0.2);
  border-radius: 22rpx;
}

.cover-box-shadow {
  position: absolute;
  right: 120rpx;
  bottom: 142rpx;
  left: 120rpx;
  height: 4rpx;
  background: rgba(31, 96, 72, 0.2);
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.stat {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 4rpx;
  padding: 18rpx 16rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 24rpx;
}

.stat-value {
  color: #151713;
  font-size: 30rpx;
  font-weight: 850;
}

.photo-carousel {
  display: grid;
  gap: 14rpx;
  padding: 18rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 30rpx;
  box-shadow: 0 22rpx 58rpx rgba(22, 25, 18, 0.08);
}

.carousel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.carousel-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  color: #425147;
  font-size: 24rpx;
  font-weight: 800;
}

.photo-swiper {
  height: 328rpx;
  overflow: hidden;
  border-radius: 24rpx;
}

.carousel-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 34rpx;
}

.carousel-dot {
  width: 14rpx;
  height: 14rpx;
  background: #a9c8b5;
  border-radius: 999rpx;
}

.carousel-dot.active {
  width: 44rpx;
  background: #1f6048;
}

.carousel-count {
  margin-left: 8rpx;
  color: #6f756d;
  font-size: 23rpx;
  font-weight: 700;
}

.carousel-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
}

.mini-button {
  height: 72rpx;
  color: #1f6048;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 72rpx;
  background: #dbe9df;
  border: 2rpx solid rgba(21, 23, 19, 0.08);
  border-radius: 22rpx;
}

.mini-button.secondary {
  color: #143e31;
  background: #eef4ef;
  border-color: rgba(21, 23, 19, 0.1);
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-flex;
  max-width: 100%;
  min-height: 56rpx;
  padding: 12rpx 18rpx;
  color: #151713;
  font-size: 24rpx;
  font-weight: 750;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 999rpx;
}

.detail-page .note-card {
  margin-top: 4rpx;
}

.quiet-note {
  display: block;
}
