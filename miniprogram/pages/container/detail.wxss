.detail-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-top: 42rpx;
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 6rpx 4rpx 2rpx;
}

.round-more {
  display: flex;
  flex: 0 0 72rpx;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  height: 72rpx;
  padding: 0;
  color: #253027;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1;
  background: #ffffff;
  border: 1rpx solid #e4ded1;
  border-radius: 50%;
}

.detail-hero {
  display: grid;
  gap: 16rpx;
}

.cover-photo {
  position: relative;
  width: 100%;
  height: 382rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(255, 253, 248, 0.45), rgba(255, 253, 248, 0)),
    #e0d4bc;
  border: 1rpx solid #e4ded1;
  border-radius: 8rpx;
  box-shadow: 0 12rpx 34rpx rgba(84, 74, 55, 0.1);
}

.cover-photo image {
  width: 100%;
  height: 100%;
}

.cover-label {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 2;
  padding: 8rpx 14rpx;
  color: #2f6f4b;
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(255, 253, 248, 0.9);
  border-radius: 999rpx;
}

.cover-placeholder {
  position: absolute;
  inset: 0;
  display: block;
  height: 100%;
}

.cover-box-line {
  position: absolute;
  right: 68rpx;
  bottom: 142rpx;
  left: 68rpx;
  height: 4rpx;
  background: rgba(118, 96, 61, 0.2);
}

.cover-box-shape {
  position: absolute;
  right: 68rpx;
  bottom: 58rpx;
  left: 68rpx;
  height: 172rpx;
  background: rgba(255, 253, 248, 0.42);
  border: 4rpx solid rgba(118, 96, 61, 0.2);
  border-radius: 8rpx;
}

.cover-box-shadow {
  position: absolute;
  right: 120rpx;
  bottom: 142rpx;
  left: 120rpx;
  height: 4rpx;
  background: rgba(118, 96, 61, 0.2);
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.stat {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 4rpx;
  padding: 18rpx 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4ded1;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 22rpx rgba(84, 74, 55, 0.06);
}

.stat-value {
  color: #253027;
  font-size: 30rpx;
  font-weight: 850;
}

.photo-carousel {
  display: grid;
  gap: 14rpx;
  padding: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e4ded1;
  border-radius: 8rpx;
  box-shadow: 0 12rpx 34rpx rgba(84, 74, 55, 0.1);
}

.carousel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.carousel-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  color: #647061;
  font-size: 24rpx;
  font-weight: 800;
}

.photo-swiper {
  height: 328rpx;
  overflow: hidden;
  border-radius: 8rpx;
}

.carousel-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 34rpx;
}

.carousel-dot {
  width: 14rpx;
  height: 14rpx;
  background: #cfd8cc;
  border-radius: 999rpx;
}

.carousel-dot.active {
  width: 44rpx;
  background: #4f8f67;
}

.carousel-count {
  margin-left: 8rpx;
  color: #697366;
  font-size: 23rpx;
  font-weight: 700;
}

.carousel-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
}

.mini-button {
  height: 72rpx;
  color: #2f6f4b;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 72rpx;
  background: #f4faf4;
  border: 1rpx solid rgba(79, 143, 103, 0.24);
}

.mini-button.secondary {
  color: #6b5b38;
  background: #fff1cf;
  border-color: rgba(232, 185, 93, 0.34);
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-flex;
  max-width: 100%;
  min-height: 56rpx;
  padding: 12rpx 18rpx;
  color: #253027;
  font-size: 24rpx;
  font-weight: 750;
  background: #ffffff;
  border: 1rpx solid #e4ded1;
  border-radius: 999rpx;
}

.detail-page .note-card {
  margin-top: 4rpx;
}
