.detail-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-top: 42rpx;
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 6rpx 4rpx 2rpx;
}

.danger-action {
  display: flex;
  flex: 0 0 96rpx;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  min-width: 96rpx;
  max-width: 96rpx;
  height: 64rpx;
  padding: 0;
  color: #a33b2f;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
  background: #f4e5df;
  border: 1rpx solid rgba(163, 59, 47, 0.18);
  border-radius: 18rpx;
}

.detail-hero {
  display: grid;
  gap: 16rpx;
}

.cover-photo {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(251, 251, 247, 0.58), rgba(219, 233, 223, 0.24)),
    #dbe9df;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 30rpx;
  box-shadow: 0 22rpx 58rpx rgba(22, 25, 18, 0.08);
}

.cover-photo image {
  width: 100%;
  height: 100%;
}

.cover-label {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 2;
  padding: 8rpx 14rpx;
  color: #143e31;
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(251, 251, 247, 0.9);
  border-radius: 999rpx;
}

.cover-placeholder {
  position: absolute;
  inset: 0;
  display: block;
  height: 100%;
}

.cover-box-line {
  position: absolute;
  right: 68rpx;
  bottom: 142rpx;
  left: 68rpx;
  height: 4rpx;
  background: rgba(31, 96, 72, 0.2);
}

.cover-box-shape {
  position: absolute;
  right: 68rpx;
  bottom: 58rpx;
  left: 68rpx;
  height: 172rpx;
  background: rgba(251, 251, 247, 0.42);
  border: 4rpx solid rgba(31, 96, 72, 0.2);
  border-radius: 22rpx;
}

.cover-box-shadow {
  position: absolute;
  right: 120rpx;
  bottom: 142rpx;
  left: 120rpx;
  height: 4rpx;
  background: rgba(31, 96, 72, 0.2);
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.stat {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 4rpx;
  padding: 18rpx 16rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 24rpx;
}

.stat-value {
  color: #151713;
  font-size: 30rpx;
  font-weight: 850;
}

.photo-carousel {
  display: grid;
  gap: 14rpx;
  padding: 18rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 30rpx;
  box-shadow: 0 22rpx 58rpx rgba(22, 25, 18, 0.08);
}

.carousel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.carousel-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  color: #425147;
  font-size: 24rpx;
  font-weight: 800;
}

.photo-swiper {
  height: 328rpx;
  overflow: hidden;
  border-radius: 24rpx;
}

.carousel-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 34rpx;
}

.carousel-dot {
  width: 14rpx;
  height: 14rpx;
  background: #a9c8b5;
  border-radius: 999rpx;
}

.carousel-dot.active {
  width: 44rpx;
  background: #1f6048;
}

.carousel-count {
  margin-left: 8rpx;
  color: #6f756d;
  font-size: 23rpx;
  font-weight: 700;
}

.carousel-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
}

.mini-button {
  height: 72rpx;
  color: #1f6048;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 72rpx;
  background: #dbe9df;
  border: 2rpx solid rgba(21, 23, 19, 0.08);
  border-radius: 22rpx;
}

.mini-button.secondary {
  color: #143e31;
  background: #eef4ef;
  border-color: rgba(21, 23, 19, 0.1);
}

.inventory-list {
  display: grid;
  gap: 10rpx;
}

.inventory-item {
  display: grid;
  gap: 10rpx;
  min-width: 0;
  padding: 14rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 26rpx;
}

.inventory-item.expanded {
  border-color: rgba(31, 96, 72, 0.22);
  box-shadow: 0 18rpx 46rpx rgba(22, 25, 18, 0.07);
}

.inventory-toolbar {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 156rpx;
  gap: 12rpx;
  align-items: center;
  min-width: 0;
  min-height: 54rpx;
}

.inventory-identity {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 12rpx;
}

.inventory-index {
  flex: none;
  width: 42rpx;
  height: 42rpx;
  color: #1f6048;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 42rpx;
  text-align: center;
  background: #dbe9df;
  border-radius: 50%;
}

.inventory-copy {
  display: grid;
  min-width: 0;
  gap: 3rpx;
}

.inventory-name {
  display: block;
  overflow: hidden;
  color: #151713;
  font-size: 27rpx;
  font-weight: 820;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.inventory-source {
  display: block;
  overflow: hidden;
  color: #6f756d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.inventory-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  justify-self: end;
  width: 156rpx;
  min-width: 156rpx;
}

.inventory-action {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 74rpx;
  max-width: 74rpx;
  height: 46rpx;
  margin: 0;
  padding: 0;
  overflow: hidden;
  color: #5a645c;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 46rpx;
  text-align: center;
  background: transparent;
  border-radius: 16rpx;
}

.inventory-action::after {
  border: 0;
}

.inventory-action.remove {
  color: #a33b2f;
  background: #f4e5df;
  border: 1rpx solid rgba(163, 59, 47, 0.16);
}

.inventory-summary {
  display: grid;
  min-width: 0;
  gap: 8rpx;
  padding-left: 54rpx;
}

.inventory-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.mini-tag {
  max-width: 100%;
  padding: 5rpx 10rpx;
  overflow: hidden;
  color: #425147;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #dbe9df;
  border: 1rpx solid rgba(21, 23, 19, 0.08);
  border-radius: 999rpx;
}

.inventory-editor {
  min-width: 0;
}

.inventory-recover {
  gap: 22rpx;
}

.recover-action {
  justify-self: start;
}

.detail-page .note-card {
  margin-top: 4rpx;
}

.quiet-note {
  display: block;
}

.recognizing-layer {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: grid;
  place-items: center;
  padding: 56rpx;
  background: rgba(251, 251, 247, 0.66);
  backdrop-filter: blur(16rpx);
}

.recognizing-card {
  width: 100%;
  max-width: 560rpx;
  padding: 44rpx;
  color: #151713;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 56rpx;
  box-shadow: 0 48rpx 108rpx rgba(22, 25, 18, 0.14);
}

.recognizing-top {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.recognizing-orbit {
  position: relative;
  display: grid;
  width: 128rpx;
  height: 128rpx;
  flex: none;
  place-items: center;
  border-radius: 50%;
}

.recognizing-orbit::before {
  position: absolute;
  inset: 10rpx;
  z-index: 0;
  content: "";
  background: #fff2c8;
  border-radius: 50%;
}

.recognizing-spinner {
  position: absolute;
  inset: 0;
  z-index: 1;
  width: 128rpx;
  height: 128rpx;
  animation: recognizing-orbit-spin 1.05s linear infinite;
  transform-origin: center;
}

.recognizing-mascot {
  position: relative;
  z-index: 2;
  width: 88rpx;
  height: 88rpx;
}

@keyframes recognizing-orbit-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.recognizing-copy {
  display: block;
  min-width: 0;
}

.recognizing-title {
  display: block;
  color: #151713;
  font-size: 38rpx;
  font-weight: 840;
  line-height: 1.2;
}

.recognizing-desc {
  display: block;
  margin-top: 12rpx;
  color: #6f756d;
  font-size: 24rpx;
  font-weight: 660;
  line-height: 1.45;
}

.recognizing-progress-pill {
  display: inline-block;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
  color: #ffffff;
  background: #1f6048;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.25;
}

.recognizing-steps {
  display: grid;
  gap: 16rpx;
  margin-top: 36rpx;
}

.recognizing-step {
  display: grid;
  grid-template-columns: 36rpx minmax(0, 1fr) auto;
  gap: 18rpx;
  align-items: center;
  color: #6f756d;
  font-size: 24rpx;
  font-weight: 720;
}

.recognizing-step.active {
  color: #151713;
}

.recognizing-dot {
  display: block;
  width: 16rpx;
  height: 16rpx;
  margin: 0 auto;
  background: rgba(31, 96, 72, 0.26);
  border-radius: 50%;
}

.recognizing-step.active .recognizing-dot {
  width: 20rpx;
  height: 20rpx;
  background: #1f6048;
}

.recognizing-state {
  color: #1f6048;
  font-size: 22rpx;
  font-weight: 820;
  white-space: nowrap;
}

.recognizing-hint {
  margin-top: 34rpx;
  padding: 22rpx 24rpx;
  color: #143e31;
  background: rgba(219, 233, 223, 0.56);
  border: 2rpx solid rgba(31, 96, 72, 0.1);
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}
