<view class="page home-page">
  <view class="page-top">
    <view class="hello">
      <text class="eyebrow">今天整理一点点</text>
      <text class="page-title">东西在哪，一搜就知道</text>
    </view>
    <button class="round-action" bindtap="goCapture">+</button>
  </view>

  <view class="hero-panel">
    <view class="hero-row">
      <view class="hero-copy">
        <text class="hero-title">物品索引已准备好</text>
        <text class="body-copy">拍箱内物品时，把手机横过来，小懒会看得更清楚。存好后，下次一搜就出来。</text>
      </view>
      <view class="mascot-orbit">
        <image class="hero-mascot" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
      </view>
    </view>
    <view class="action-grid">
      <button class="primary-button" bindtap="goCapture">拍一箱</button>
      <button class="soft-button" bindtap="goSearch">找东西</button>
    </view>
  </view>

  <view wx:if="{{showExpiryReminderEntry}}" class="expiry-reminder-entry" bindtap="openExpiryReminders">
    <view class="expiry-reminder-mascot">
      <image mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
    </view>
    <view class="expiry-reminder-copy">
      <text class="expiry-reminder-title">小懒盯到 {{expiryReminderCount}} 件快到期</text>
      <text class="subtle">{{expiryReminderPreview}}</text>
    </view>
    <text class="expiry-reminder-action">看看</text>
  </view>

  <view wx:if="{{showExpiryReminderPanel}}" class="expiry-reminder-sheet">
    <view class="expiry-reminder-scrim" bindtap="closeExpiryReminderDetails"></view>
    <view class="expiry-reminder-panel">
      <view class="expiry-reminder-panel-head">
        <view>
          <text class="expiry-reminder-panel-title">小懒提醒你</text>
          <text class="expiry-reminder-panel-subtitle">{{expiryReminderPreview}}</text>
        </view>
        <button class="expiry-reminder-close" bindtap="closeExpiryReminderDetails">×</button>
      </view>
      <scroll-view class="expiry-reminder-detail-list" scroll-y="{{true}}">
        <view
          wx:for="{{expiryReminderDetails}}"
          wx:key="_id"
          class="expiry-reminder-detail"
        >
          <view class="expiry-reminder-detail-photo">
            <image wx:if="{{item.hasImage}}" mode="aspectFill" lazy-load="{{true}}" src="{{item.imagePath}}"></image>
            <image wx:if="{{item.showImagePlaceholder}}" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
          </view>
          <view class="expiry-reminder-detail-copy">
            <text class="expiry-detail-name">{{item.displayName}}</text>
            <text class="expiry-detail-location">{{item.containerText}}</text>
            <view class="expiry-detail-meta">
              <text class="expiry-detail-date">{{item.expiryDateText}}</text>
              <text class="expiry-detail-days">{{item.remainingDaysText}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="expiry-reminder-action-bar">
        <button class="expiry-reminder-done" bindtap="confirmExpiryReminderDetails">我知道啦</button>
      </view>
    </view>
  </view>

  <view class="section-row">
    <text class="section-heading">最近整理</text>
    <text class="text-link" bindtap="showContainers">全部容器</text>
  </view>

  <view wx:if="{{hasRecentContainers}}" class="container-stack">
    <view
      wx:for="{{recentContainers}}"
      wx:key="_id"
      class="container-row"
      bindtap="openContainer"
      data-id="{{item._id}}"
    >
      <view class="container-thumb tone-{{index}}">
        <image wx:if="{{item.coverPhoto}}" mode="aspectFill" lazy-load="{{true}}" src="{{item.coverPhoto}}"></image>
        <view wx:if="{{item.showPlaceholder}}" class="photo-illustration">
          <view class="illu-line wide"></view>
          <view class="illu-line"></view>
          <view class="illu-dot"></view>
        </view>
      </view>
      <view class="container-meta">
        <text class="container-name">{{item.name}}</text>
        <text class="subtle">{{item.displayLocation}}</text>
        <view class="container-pills">
          <text class="pill">{{item.itemCount}} 件物品</text>
          <text class="pill">{{item.displayStatus}}</text>
        </view>
      </view>
    </view>
  </view>
  <view wx:if="{{showEmptyRecentContainers}}" class="empty-state with-xiaolan">
    <view class="xiaolan-row">
      <image class="xiaolan-avatar" mode="aspectFit" src="/assets/xiaolan-sloth.svg"></image>
      <view class="xiaolan-copy">
        <text class="xiaolan-name">小懒还没有东西可找</text>
        <text>先拍一箱，保存后这里会像相册一样展示。</text>
      </view>
    </view>
    <button class="empty-action" bindtap="goCapture">拍照整理</button>
  </view>
</view>
