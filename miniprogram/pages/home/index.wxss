.home-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-top: 26rpx;
  padding-bottom: 154rpx;
  background:
    linear-gradient(90deg, rgba(21, 23, 19, 0.035) 1px, transparent 1px) 0 0 / 72rpx 72rpx,
    linear-gradient(180deg, #f7f6f1 0%, #f3f2ed 100%);
}

.page-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding-top: 0;
}

.hello {
  min-width: 0;
  flex: 1;
}

.round-action {
  display: flex;
  flex: 0 0 72rpx;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  height: 72rpx;
  padding: 0;
  color: #1f6048;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 50%;
  box-shadow: 0 18rpx 38rpx rgba(22, 25, 18, 0.08);
}

.hero-panel {
  display: grid;
  gap: 36rpx;
  max-width: 100%;
  margin-top: 24rpx;
  padding: 40rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8f8f3 100%);
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 56rpx;
}

.hero-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 152rpx;
  gap: 24rpx;
  align-items: center;
}

.hero-copy {
  display: grid;
  gap: 10rpx;
  min-width: 0;
}

.hero-title {
  display: block;
  color: #151713;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.22;
}

.body-copy {
  display: block;
  margin-top: 14rpx;
  color: #6f756d;
  font-size: 26rpx;
  line-height: 1.55;
}

.mascot-orbit {
  display: grid;
  place-items: center;
  width: 152rpx;
  height: 152rpx;
  background: #fff2c8;
  border: 2rpx solid rgba(21, 23, 19, 0.08);
  border-radius: 48rpx;
}

.hero-mascot {
  width: 116rpx;
  height: 116rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  min-width: 0;
}

.action-grid .primary-button,
.action-grid .soft-button {
  min-width: 0;
  max-width: 100%;
  height: 100rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
}

.expiry-reminder-entry {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) auto;
  align-items: center;
  gap: 18rpx;
  min-height: 112rpx;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: #fff7dc;
  border: 2rpx solid rgba(117, 100, 68, 0.16);
  border-radius: 28rpx;
}

.expiry-reminder-mascot {
  display: grid;
  place-items: center;
  width: 72rpx;
  height: 72rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.08);
  border-radius: 24rpx;
}

.expiry-reminder-mascot image {
  width: 54rpx;
  height: 54rpx;
}

.expiry-reminder-copy {
  display: grid;
  gap: 6rpx;
  min-width: 0;
}

.expiry-reminder-title {
  overflow: hidden;
  color: #151713;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.expiry-reminder-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 84rpx;
  height: 56rpx;
  padding: 0 20rpx;
  color: #1f6048;
  font-size: 24rpx;
  font-weight: 800;
  background: #fbfbf7;
  border-radius: 999rpx;
}

.expiry-reminder-sheet {
  position: fixed;
  inset: 0;
  z-index: 60;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 28rpx calc(20rpx + env(safe-area-inset-bottom));
}

.expiry-reminder-scrim {
  position: absolute;
  inset: 0;
  background: rgba(21, 23, 19, 0.28);
}

.expiry-reminder-panel {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  gap: 18rpx;
  width: 100%;
  max-height: 78vh;
  overflow: hidden;
  padding: 28rpx 24rpx 0;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 30rpx 30rpx 0 0;
  box-shadow: 0 -18rpx 46rpx rgba(22, 25, 18, 0.16);
}

.expiry-reminder-panel-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 56rpx;
  align-items: start;
  gap: 16rpx;
}

.expiry-reminder-panel-title {
  display: block;
  color: #151713;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.expiry-reminder-panel-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #6f756d;
  font-size: 24rpx;
  line-height: 1.45;
}

.expiry-reminder-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  color: #1f6048;
  font-size: 34rpx;
  line-height: 1;
  background: #eef5ef;
  border-radius: 50%;
}

.expiry-reminder-detail-list {
  min-height: 0;
  max-height: 820rpx;
}

.expiry-reminder-detail {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  min-height: 136rpx;
  padding: 14rpx 0;
  border-top: 2rpx solid rgba(21, 23, 19, 0.08);
}

.expiry-reminder-detail-photo {
  display: grid;
  place-items: center;
  width: 112rpx;
  height: 112rpx;
  overflow: hidden;
  background: #fff2c8;
  border-radius: 22rpx;
}

.expiry-reminder-detail-photo image {
  width: 100%;
  height: 100%;
}

.expiry-reminder-detail-photo image[mode="aspectFit"] {
  width: 78rpx;
  height: 78rpx;
}

.expiry-reminder-detail-copy {
  display: grid;
  gap: 8rpx;
  min-width: 0;
}

.expiry-detail-name {
  overflow: hidden;
  color: #151713;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.expiry-detail-location {
  overflow: hidden;
  color: #6f756d;
  font-size: 24rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.expiry-detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.expiry-detail-date,
.expiry-detail-days {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 14rpx;
  color: #1f6048;
  font-size: 22rpx;
  font-weight: 800;
  background: #e1eee5;
  border-radius: 999rpx;
}

.expiry-detail-days {
  color: #7b5b1d;
  background: #fff2c8;
}

.expiry-reminder-action-bar {
  padding: 14rpx 0 22rpx;
  background: #fbfbf7;
}

.expiry-reminder-done {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  margin: 0;
  color: #fbfbf7;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 82rpx;
  background: #1f6048;
  border-radius: 999rpx;
}

.container-stack {
  display: grid;
  gap: 14rpx;
}

.container-row {
  display: grid;
  grid-template-columns: 164rpx minmax(0, 1fr);
  align-items: center;
  gap: 18rpx;
  min-height: 190rpx;
  padding: 14rpx;
  background: #fbfbf7;
  border: 2rpx solid rgba(21, 23, 19, 0.12);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 46rpx rgba(22, 25, 18, 0.07);
}

.container-thumb {
  position: relative;
  width: 100%;
  height: 164rpx;
  overflow: hidden;
  background: #dbe9df;
  border-radius: 22rpx;
}

.container-thumb image {
  width: 100%;
  height: 100%;
}

.tone-1 {
  background: #e7ede2;
}

.tone-2 {
  background: #dde9e8;
}

.tone-3 {
  background: #e9e7d9;
}

.photo-illustration {
  position: relative;
  width: 100%;
  height: 100%;
}

.illu-line {
  position: absolute;
  left: 28rpx;
  bottom: 44rpx;
  width: 86rpx;
  height: 18rpx;
  background: rgba(31, 96, 72, 0.26);
  border-radius: 6rpx;
}

.illu-line.wide {
  bottom: 74rpx;
  width: 132rpx;
  background: rgba(251, 251, 247, 0.78);
  box-shadow: inset 0 0 0 1rpx rgba(21, 23, 19, 0.08);
}

.illu-dot {
  position: absolute;
  right: 30rpx;
  bottom: 34rpx;
  width: 62rpx;
  height: 74rpx;
  background: rgba(251, 251, 247, 0.7);
  border-radius: 8rpx;
  box-shadow: inset 0 0 0 1rpx rgba(117, 100, 68, 0.08);
}

.container-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.container-name {
  overflow: hidden;
  color: #151713;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.container-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
