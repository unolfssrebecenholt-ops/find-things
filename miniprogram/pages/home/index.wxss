.home-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-top: 26rpx;
  padding-bottom: 154rpx;
  background:
    linear-gradient(180deg, #fff9ec 0%, #f4faee 54%, #fff7e8 100%);
}

.page-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding-top: 0;
}

.hello {
  min-width: 0;
  flex: 1;
}

.round-action {
  display: flex;
  flex: 0 0 72rpx;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  height: 72rpx;
  padding: 0;
  color: #ff7a59;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 50%;
  box-shadow: 0 8rpx 0 #f1e4c8;
}

.hero-card {
  position: relative;
  display: grid;
  gap: 20rpx;
  margin-top: 24rpx;
  padding: 28rpx;
  overflow: hidden;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 34rpx;
  box-shadow: 0 12rpx 0 #f1e4c8;
}

.hero-card::before {
  position: absolute;
  top: 18rpx;
  right: 28rpx;
  width: 120rpx;
  height: 22rpx;
  content: "";
  background: #fff0b8;
  border-radius: 999rpx;
  transform: rotate(-8deg);
}

.hero-topline {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 104rpx;
  gap: 18rpx;
  align-items: center;
}

.hero-copy {
  display: grid;
  gap: 10rpx;
}

.hero-title {
  display: block;
  color: #2f352c;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.22;
}

.hero-mascot {
  width: 104rpx;
  height: 104rpx;
}

.hero-actions {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 16rpx;
  min-width: 0;
  overflow: hidden;
}

.hero-actions .primary-button {
  box-shadow: 0 8rpx 0 #d9553a;
}

.album-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.album-card {
  overflow: hidden;
  background: #fffdf8;
  border: 2rpx solid #eadfc8;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 0 #f1e4c8;
}

.album-photo {
  position: relative;
  width: 100%;
  height: 186rpx;
  overflow: hidden;
  background: #dff3df;
}

.album-photo image {
  width: 100%;
  height: 100%;
}

.tone-1 {
  background: #ffe6c8;
}

.tone-2 {
  background: #e8edc7;
}

.tone-3 {
  background: #dfeefd;
}

.album-count {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  z-index: 2;
  padding: 6rpx 12rpx;
  color: #7b5e1e;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  opacity: 0;
  background: rgba(255, 250, 238, 0.9);
  border-radius: 999rpx;
}

.photo-illustration {
  position: relative;
  width: 100%;
  height: 100%;
}

.illu-line {
  position: absolute;
  left: 28rpx;
  bottom: 44rpx;
  width: 86rpx;
  height: 18rpx;
  background: rgba(255, 122, 89, 0.42);
  border-radius: 6rpx;
}

.illu-line.wide {
  bottom: 74rpx;
  width: 132rpx;
  background: rgba(255, 253, 248, 0.72);
  box-shadow: inset 0 0 0 1rpx rgba(117, 100, 68, 0.08);
}

.illu-dot {
  position: absolute;
  right: 30rpx;
  bottom: 34rpx;
  width: 62rpx;
  height: 74rpx;
  background: rgba(255, 253, 248, 0.7);
  border-radius: 8rpx;
  box-shadow: inset 0 0 0 1rpx rgba(117, 100, 68, 0.08);
}

.album-meta {
  display: flex;
  min-height: 112rpx;
  flex-direction: column;
  gap: 6rpx;
  padding: 14rpx 16rpx 16rpx;
}

.album-name {
  overflow: hidden;
  color: #2f352c;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-page .bottom-nav {
  right: 0;
  bottom: 0;
  left: 0;
  gap: 0;
  min-height: 112rpx;
  padding: 12rpx 28rpx 18rpx;
  background: rgba(255, 253, 248, 0.96);
  border-right: 0;
  border-bottom: 0;
  border-left: 0;
  border-radius: 0;
  box-shadow: none;
}

.home-page .nav-item.active {
  background: transparent;
}
