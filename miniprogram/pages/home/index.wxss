.home-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-top: 26rpx;
  padding-bottom: 154rpx;
  background:
    radial-gradient(circle at 4% 0, rgba(232, 185, 93, 0.14), transparent 32%),
    linear-gradient(180deg, #fffdf8 0%, #f7f3ea 100%);
}

.page-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding-top: 0;
}

.hello {
  min-width: 0;
  flex: 1;
}

.round-action {
  display: flex;
  flex: 0 0 72rpx;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  height: 72rpx;
  padding: 0;
  color: #2f6f4b;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid #e4ded1;
  border-radius: 50%;
  box-shadow: 0 10rpx 22rpx rgba(84, 74, 55, 0.07);
}

.hero-card {
  display: grid;
  gap: 20rpx;
  margin-top: 24rpx;
  padding: 26rpx;
  background:
    linear-gradient(135deg, rgba(229, 240, 231, 0.96), rgba(255, 253, 248, 0.98) 74%),
    #fffdf8;
  border: 1rpx solid rgba(79, 143, 103, 0.18);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 48rpx rgba(70, 86, 59, 0.11);
}

.hero-copy {
  display: grid;
  gap: 10rpx;
}

.hero-title {
  display: block;
  color: #253027;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.22;
}

.hero-actions {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 16rpx;
  min-width: 0;
  overflow: hidden;
}

.hero-actions .primary-button {
  box-shadow: 0 14rpx 30rpx rgba(79, 143, 103, 0.22);
}

.album-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.album-card {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e4ded1;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(89, 79, 55, 0.06);
}

.album-photo {
  position: relative;
  width: 100%;
  height: 154rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(255, 253, 248, 0.54), rgba(255, 253, 248, 0)),
    #d8e6e0;
}

.album-photo image {
  width: 100%;
  height: 100%;
}

.tone-1 {
  background:
    linear-gradient(135deg, rgba(255, 253, 248, 0.56), rgba(255, 253, 248, 0)),
    #e8dcc3;
}

.tone-2 {
  background:
    linear-gradient(135deg, rgba(255, 253, 248, 0.54), rgba(255, 253, 248, 0)),
    #d9ddc5;
}

.tone-3 {
  background:
    linear-gradient(135deg, rgba(255, 253, 248, 0.5), rgba(255, 253, 248, 0)),
    #d9e5d6;
}

.album-count {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  z-index: 2;
  padding: 6rpx 12rpx;
  color: #2f6f4b;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  opacity: 0;
  background: rgba(255, 253, 248, 0.72);
  border-radius: 999rpx;
}

.photo-illustration {
  position: relative;
  width: 100%;
  height: 100%;
}

.illu-line {
  position: absolute;
  left: 28rpx;
  bottom: 44rpx;
  width: 86rpx;
  height: 18rpx;
  background: rgba(47, 111, 75, 0.38);
  border-radius: 6rpx;
}

.illu-line.wide {
  bottom: 74rpx;
  width: 132rpx;
  background: rgba(255, 253, 248, 0.62);
  box-shadow: inset 0 0 0 1rpx rgba(117, 100, 68, 0.08);
}

.illu-dot {
  position: absolute;
  right: 30rpx;
  bottom: 34rpx;
  width: 62rpx;
  height: 74rpx;
  background: rgba(255, 253, 248, 0.56);
  border-radius: 8rpx;
  box-shadow: inset 0 0 0 1rpx rgba(117, 100, 68, 0.08);
}

.album-meta {
  display: flex;
  min-height: 112rpx;
  flex-direction: column;
  gap: 6rpx;
  padding: 14rpx 16rpx 16rpx;
}

.album-name {
  overflow: hidden;
  color: #253027;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-page .bottom-nav {
  right: 0;
  bottom: 0;
  left: 0;
  gap: 0;
  min-height: 112rpx;
  padding: 12rpx 28rpx 18rpx;
  background: rgba(255, 253, 248, 0.94);
  border-right: 0;
  border-bottom: 0;
  border-left: 0;
  border-radius: 0;
  box-shadow: 0 -10rpx 28rpx rgba(84, 74, 55, 0.08);
}

.home-page .nav-item.active {
  background: transparent;
}
